---
import { client } from "../utils/sanity-client";
import SectionLayout from "../layouts/SectionLayout.astro";
import { fetchTeachingSubpages, TEACHING_BASE_PATH, toSectionNavItems } from "../data/sectionNav";
import { PORTABLE_BODY } from "../data/portableText";

const [teachingPage, teachingSubpages] = await Promise.all([client.fetch(
  `*[_type == "teachingPage"][0]{
    title,
    shortTitle,
    intro,
    ${PORTABLE_BODY}
  }`
), fetchTeachingSubpages()]);

const title = teachingPage?.title ?? "Teaching";
const intro = teachingPage?.intro ?? "";
const body = teachingPage?.body ?? [];
const secondaryNavItems = toSectionNavItems(teachingSubpages, TEACHING_BASE_PATH);
---

<SectionLayout
  title={title}
  intro={intro}
  body={body}
  secondaryNavTitle="Teaching"
  secondaryNavItems={secondaryNavItems}
  currentPath={TEACHING_BASE_PATH}
/>
