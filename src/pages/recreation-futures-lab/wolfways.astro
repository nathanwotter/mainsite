---
import Layout from "../../layouts/Layout.astro";
import SecondaryNav from "../../components/SecondaryNav.astro";
import WolfWaysMap from "../../components/WolfWaysMap.astro";

const title = "WolfWays: Explore Recreation at NC State";
const description =
  "A mobile-first campus guide for discovering recreation and leisure experiences around NC State.";
const maptilerKey = import.meta.env.PUBLIC_MAPTILER_KEY ?? "";

// TODO: Replace these prototype locations with a Sanity-powered place schema.
// TODO: Add the future social/check-in layer only after the static guide is validated.
const locations = [
  {
    id: "lake-raleigh-docks-boat-ramp",
    name: "Lake Raleigh Docks and Boat Ramp",
    // TODO: Verify exact GPS coordinates for the Lake Raleigh docks and boat ramp.
    latitude: 35.7755,
    longitude: -78.6815,
    category: "Outdoor Recreation / Waterfront",
    shortDescription:
      "A lakeside recreation spot on Centennial Campus with docks, water views, and access to Lake Raleigh.",
    ncStateOfRecreation360Url: "#",
    recxrSlug: "",
    externalInfoUrl: "#",
    contributor: "NC:State of Recreation prototype",
    images: []
  },
  {
    id: "talley-student-union",
    name: "Talley Student Union",
    latitude: 35.7839,
    longitude: -78.6712,
    category: "Campus Life / Gathering",
    shortDescription:
      "A central campus hub for meeting up, relaxing between classes, and finding student-centered events.",
    ncStateOfRecreation360Url: "#",
    recxrSlug: "",
    externalInfoUrl: "#",
    contributor: "WolfWays prototype",
    images: []
  },
  {
    id: "carmichael-gym",
    name: "Carmichael Gym / Wellness and Recreation",
    latitude: 35.7827,
    longitude: -78.6742,
    category: "Wellness / Indoor Recreation",
    shortDescription:
      "A prototype pin for NC State Wellness and Recreation spaces, fitness programs, and active campus life.",
    ncStateOfRecreation360Url: "#",
    recxrSlug: "",
    externalInfoUrl: "#",
    contributor: "WolfWays prototype",
    images: []
  },
  {
    id: "court-of-north-carolina",
    name: "Court of North Carolina",
    latitude: 35.7852,
    longitude: -78.6699,
    category: "Outdoor Campus Space",
    shortDescription:
      "A historic green space for walking, studying outside, informal games, and campus downtime.",
    ncStateOfRecreation360Url: "#",
    recxrSlug: "",
    externalInfoUrl: "#",
    contributor: "WolfWays prototype",
    images: []
  },
  {
    id: "the-oval-centennial-campus",
    name: "The Oval / Centennial Campus",
    latitude: 35.771,
    longitude: -78.6748,
    category: "Campus Commons / Centennial Campus",
    shortDescription:
      "A Centennial Campus gathering space near academic buildings, dining, and open lawns.",
    ncStateOfRecreation360Url: "#",
    recxrSlug: "",
    externalInfoUrl: "#",
    contributor: "WolfWays prototype",
    images: []
  }
];

const secondaryNavItems = [
  {
    _type: "actionLink",
    label: "Recreation Futures Lab",
    url: "/recreation-futures-lab",
    ariaLabel: "Recreation Futures Lab"
  },
  {
    _type: "actionLink",
    label: "NC:State of Recreation",
    url: "/recreation-futures-lab/nc-state-of-recreation",
    ariaLabel: "NC:State of Recreation"
  },
  {
    _type: "actionLink",
    label: "WolfWays",
    url: "/recreation-futures-lab/wolfways",
    ariaLabel: "WolfWays"
  }
];
---

<Layout title={title} description={description}>
  <SecondaryNav
    slot="secondary-nav"
    title="Recreation Futures Lab"
    items={secondaryNavItems}
    currentPath="/recreation-futures-lab/wolfways"
  />

  <section class="wolfways-hero">
    <p class="wolfways-kicker">Campus recreation guide</p>
    <h1>{title}</h1>
    <p>
      WolfWays is a clean, mobile-first guide for discovering recreation,
      leisure, and restorative outdoor moments around NC State. This first
      prototype starts with a map of Main Campus, Centennial Campus, and Lake
      Raleigh.
    </p>
  </section>

  <WolfWaysMap maptilerKey={maptilerKey} locations={locations} />

  <section class="wolfways-location-list" aria-label="Prototype WolfWays locations">
    <div class="wolfways-section-heading">
      <p class="wolfways-kicker">Prototype places</p>
      <h2>Start With These Campus Spots</h2>
    </div>
    <div class="wolfways-cards">
      {
        locations.map((location) => {
          const recxrHref = location.recxrSlug
            ? `/recreation-futures-lab/recxr/${location.recxrSlug}`
            : location.recxrUrl;

          return (
            <article class="wolfways-card">
              <div class="wolfways-card-image">Pictures placeholder</div>
              <div class="wolfways-card-body">
                <p class="wolfways-card-category">{location.category}</p>
                <h3>{location.name}</h3>
                <p>{location.shortDescription}</p>
                <div class="wolfways-card-actions">
                  <a href={location.ncStateOfRecreation360Url}>NC:State 360 Video</a>
                  {recxrHref ? (
                    <a href={recxrHref}>Open RecXR</a>
                  ) : (
                    <span aria-disabled="true">RecXR coming soon</span>
                  )}
                  <a
                    href={location.externalInfoUrl}
                    class:list={[location.externalInfoUrl === "#" && "is-disabled"]}
                    aria-disabled={location.externalInfoUrl === "#" ? "true" : undefined}
                  >
                    Organization info
                  </a>
                </div>
                <p class="wolfways-card-contributor">Contributor: {location.contributor}</p>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</Layout>

<style>
  .wolfways-hero {
    max-width: 860px;
    padding: 2.75rem 0 0.75rem;
  }

  .wolfways-kicker {
    margin: 0 0 0.65rem;
    color: #b42318;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .wolfways-hero h1 {
    max-width: 820px;
    margin: 0 0 1rem;
    font-size: clamp(2.1rem, 8vw, 4.4rem);
    line-height: 1;
  }

  .wolfways-hero p:last-child {
    max-width: 720px;
    margin: 0;
    color: color-mix(in oklab, var(--color-base-content) 82%, transparent);
    font-size: clamp(1.05rem, 2.6vw, 1.25rem);
    line-height: 1.65;
  }

  .wolfways-location-list {
    padding: 1rem 0 4rem;
  }

  .wolfways-section-heading {
    max-width: 760px;
    margin-bottom: 1rem;
  }

  .wolfways-section-heading h2 {
    margin: 0;
    font-size: clamp(1.55rem, 4vw, 2.25rem);
    line-height: 1.1;
  }

  .wolfways-cards {
    display: grid;
    gap: 1rem;
  }

  .wolfways-card {
    display: grid;
    gap: 0;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-base-200) 78%, transparent);
    border-radius: 8px;
    background: #ffffff;
  }

  .wolfways-card-image {
    display: grid;
    min-height: 9.5rem;
    place-items: center;
    background:
      linear-gradient(135deg, rgba(204, 0, 0, 0.1), transparent 52%),
      #e9f0eb;
    color: #4b5563;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .wolfways-card-body {
    padding: 1rem;
  }

  .wolfways-card-category {
    margin: 0 0 0.35rem;
    color: #5d6b31;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .wolfways-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.22rem;
    line-height: 1.2;
  }

  .wolfways-card p {
    margin: 0;
    line-height: 1.6;
  }

  .wolfways-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1rem 0;
  }

  .wolfways-card-actions a,
  .wolfways-card-actions span {
    display: inline-flex;
    min-height: 2.65rem;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.95rem;
    border: 1px solid #171227;
    border-radius: 999px;
    color: #171227;
    font-weight: 800;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
  }

  .wolfways-card-actions a:first-child {
    border-color: #cc0000;
    background: #cc0000;
    color: #ffffff;
  }

  .wolfways-card-actions span,
  .wolfways-card-actions .is-disabled {
    border-color: #d7d8e4;
    background: #f3f4f6;
    color: #6b7280;
  }

  .wolfways-card-contributor {
    color: #60656f;
    font-size: 0.9rem;
  }

  @media (min-width: 48rem) {
    .wolfways-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
