---
import { client } from "../../utils/sanity-client";
import SectionLayout from "../../layouts/SectionLayout.astro";
import { NC_STATE_PARENT_SLUG } from "../../data/ncStateOfRecreation";
import {
  fetchRecreationFuturesSubpages,
  RECREATION_FUTURES_BASE_PATH,
  toSectionNavItems
} from "../../data/sectionNav";
import { PORTABLE_BODY } from "../../data/portableText";

export async function getStaticPaths() {
  const slugs = await client.fetch(
    `*[_type == "recreationFuturesSubpage" && defined(slug.current)]{
      "slug": slug.current
    }`
  );

  return slugs
    .filter(({ slug }: { slug: string }) => slug !== NC_STATE_PARENT_SLUG)
    .map(({ slug }: { slug: string }) => ({
      params: { slug },
    }));
}

const { slug } = Astro.params;

const [recreationFuturesSubpage, recreationFuturesSubpages] = await Promise.all([
  slug
    ? client.fetch(
        `*[_type == "recreationFuturesSubpage" && slug.current == $slug][0]{
          title,
          shortTitle,
          intro,
          ${PORTABLE_BODY}
        }`,
        { slug }
      )
    : null,
  fetchRecreationFuturesSubpages()
]);

const title = recreationFuturesSubpage?.title ?? "Recreation Futures Lab";
const intro = recreationFuturesSubpage?.intro ?? "";
const body = recreationFuturesSubpage?.body ?? [];
const secondaryNavItems = toSectionNavItems(recreationFuturesSubpages, RECREATION_FUTURES_BASE_PATH);
---

<SectionLayout
  title={title}
  intro={intro}
  body={body}
  secondaryNavTitle="Recreation Futures Lab"
  secondaryNavItems={secondaryNavItems}
  currentPath={`${RECREATION_FUTURES_BASE_PATH}/${slug}`}
  showTitleHeading={false}
/>
