---
import Layout from "../../../layouts/Layout.astro";
import { client } from "../../../utils/sanity-client";
import { PortableText } from "astro-portabletext";
import RecxrArGuide from "../../../components/RecxrArGuide.astro";
import RecxrImageTargetGuide from "../../../components/RecxrImageTargetGuide.astro";

export async function getStaticPaths() {
  const slugs = await client.fetch(
    `*[_type == "recxrSite" && defined(slug.current)]{
      "slug": slug.current
    }`
  );

  return slugs.map(({ slug }: { slug: string }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

const recxrSite = slug
  ? await client.fetch(
      `*[_type == "recxrSite" && slug.current == $slug][0]{
        title,
        shortTitle,
        locationName,
        activityName,
        intro,
        body,
        latitude,
        longitude,
        activationRadiusMeters,
        guideVideoUrl,
        fallbackVideoUrl,
        safetyNotes,
        experienceStops[]{
          title,
          slug,
          description,
          latitude,
          longitude,
          activationRadiusMeters,
          order,
          anchorMode,
          imageTargetName,
          imageTargetWidth,
          anchorOffsetX,
          anchorOffsetY,
          anchorOffsetZ,
          anchorYaw,
          videoMode,
          promptText,
          standardVideo{
            asset->{
              playbackId,
              assetId,
              filename
            }
          },
          arGuideVideo{
            asset->{
              playbackId,
              assetId,
              filename
            }
          },
          video{
            asset->{
              playbackId,
              assetId,
              filename
            }
          }
        }
      }`,
      { slug }
    )
  : null;

const title = recxrSite?.title ?? "RecXR Experience";
const locationName = recxrSite?.locationName ?? "Location to be announced";
const activityName = recxrSite?.activityName ?? "RecXR Pilot Experience";
const intro = recxrSite?.intro ?? "";
const body = recxrSite?.body ?? [];
const guideVideoUrl = recxrSite?.guideVideoUrl ?? "";
const fallbackVideoUrl = recxrSite?.fallbackVideoUrl ?? "";
const safetyNotes = recxrSite?.safetyNotes ?? [];
const hasCoordinates = typeof recxrSite?.latitude === "number" && typeof recxrSite?.longitude === "number";
const activationRadiusMeters = recxrSite?.activationRadiusMeters;
const experienceStops = [...(recxrSite?.experienceStops ?? [])]
  .sort((a, b) => (a?.order ?? 999) - (b?.order ?? 999))
  .map((stop, index) => {
    const legacyPlaybackId = stop?.video?.asset?.playbackId;
    const standardPlaybackId = stop?.standardVideo?.asset?.playbackId ?? legacyPlaybackId;
    const arGuidePlaybackId =
      stop?.arGuideVideo?.asset?.playbackId ??
      (stop?.videoMode === "packedAlpha" ? legacyPlaybackId : "");

    return {
      ...stop,
      index,
      anchorMode: stop?.anchorMode ?? "world",
      imageTargetName: stop?.imageTargetName ?? "",
      imageTargetWidth: typeof stop?.imageTargetWidth === "number" ? stop.imageTargetWidth : null,
      anchorOffsetX: typeof stop?.anchorOffsetX === "number" ? stop.anchorOffsetX : 0,
      anchorOffsetY: typeof stop?.anchorOffsetY === "number" ? stop.anchorOffsetY : 0,
      anchorOffsetZ: typeof stop?.anchorOffsetZ === "number" ? stop.anchorOffsetZ : 0,
      anchorYaw: typeof stop?.anchorYaw === "number" ? stop.anchorYaw : 0,
      videoMode: stop?.videoMode ?? (arGuidePlaybackId ? "packedAlpha" : "standard"),
      playbackId: standardPlaybackId ?? legacyPlaybackId ?? "",
      standardPlaybackId: standardPlaybackId ?? "",
      arGuidePlaybackId: arGuidePlaybackId ?? "",
      hlsUrl: standardPlaybackId ? `https://stream.mux.com/${standardPlaybackId}.m3u8` : "",
      standardHlsUrl: standardPlaybackId ? `https://stream.mux.com/${standardPlaybackId}.m3u8` : "",
      arGuideHlsUrl: arGuidePlaybackId ? `https://stream.mux.com/${arGuidePlaybackId}.m3u8` : "",
    };
  });

---

<Layout title={title}>
  <section style="padding: 2rem 0 3rem 0;">
    <div style="max-width: 900px; line-height: 1.7;">
      <p style="font-size: 0.9rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem; color: #666;">
        RecXR Pilot
      </p>
      <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; margin: 0 0 1rem 0;">
        {title}
      </h1>
      <p style="margin: 0 0 0.5rem 0;"><strong>Location:</strong> {locationName}</p>
      <p style="margin: 0 0 1rem 0;"><strong>Activity:</strong> {activityName}</p>
      {intro && <p style="margin: 0;">{intro}</p>}
    </div>
  </section>

  <section style="padding: 0 0 2rem 0;">
    <div style="max-width: 900px; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; background: #fafafa;">
      <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">Viewer Mode</h2>
      <p style="margin: 0;">
        This is the current RecXR pilot viewer for testing site content, stop sequencing, and video playback. Geolocation unlocking and AR guide placement will come later.
      </p>
    </div>
  </section>

  <section style="padding: 0 0 2rem 0;">
    <div style="max-width: 900px; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px;">
      <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">Geolocation Status</h2>
      <p style="margin: 0 0 0.5rem 0;">
        This pilot will later support geolocation unlocking and AR guide placement. The current version is focused on content architecture only.
      </p>
      <p style="margin: 0 0 0.5rem 0;">
        <strong>Coordinates configured:</strong> {hasCoordinates ? "Yes" : "Not yet"}
      </p>
      {hasCoordinates && (
        <p style="margin: 0 0 0.5rem 0;">
          <strong>Site coordinates:</strong> {recxrSite.latitude}, {recxrSite.longitude}
        </p>
      )}
      {typeof activationRadiusMeters === "number" && (
        <p style="margin: 0;">
          <strong>Activation radius:</strong> {activationRadiusMeters} meters
        </p>
      )}
      <div style="margin-top: 1rem; display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
        <button
          id="recxr-geolocate"
          type="button"
          style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #222; text-decoration: none; color: #fff; background: #222; border-radius: 999px; cursor: pointer;"
        >
          Request My Location
        </button>
        <p id="recxr-geolocate-status" style="margin: 0; color: #555;">
          Location permission not requested yet.
        </p>
      </div>
      <p id="recxr-geolocate-coords" style="margin: 0.75rem 0 0 0; color: #555;"></p>
    </div>
  </section>

  <section style="padding: 0 0 2rem 0;">
    <div id="recxr-active-stop" style="max-width: 900px; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; background: linear-gradient(180deg, #fcfbff, #f6f4fa);">
      <div style="display: grid; gap: 1rem; align-items: start;">
        <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: start; flex-wrap: wrap;">
          <div>
            <p style="margin: 0 0 0.35rem 0; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #6b21a8;">
              Current Stop
            </p>
            <h2 style="font-size: 1.4rem; margin: 0;">On-Site Guide</h2>
          </div>
          <p id="recxr-active-stop-status" style="margin: 0; padding: 0.45rem 0.8rem; border-radius: 999px; background: #ede9fe; color: #5b21b6; font-weight: 700;">
            Locked
          </p>
        </div>

        <div style="display: grid; gap: 1rem; grid-template-columns: minmax(0, 1.7fr) minmax(260px, 1fr);">
          <div style="padding: 1.1rem; border-radius: 16px; border: 1px solid #e9e2f7; background: rgba(255,255,255,0.72);">
            <p id="recxr-active-stop-sequence" style="margin: 0 0 0.4rem 0; font-size: 0.9rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #7c3aed;">
              Route status pending
            </p>
            <h3 id="recxr-active-stop-name" style="margin: 0 0 0.6rem 0; font-size: 1.5rem; line-height: 1.15;">Nearest stop: not detected yet.</h3>
            <p id="recxr-active-stop-description" style="margin: 0 0 0.75rem 0; line-height: 1.7; color: #3f3f46;">
              This stop will become more descriptive once the page knows where the visitor is standing.
            </p>
            <p id="recxr-active-stop-distance" style="margin: 0 0 0.9rem 0; color: #555;">Distance: unavailable</p>
            <div style="padding: 0.95rem 1rem; border-radius: 14px; background: #f3f0ff; border: 1px solid #e4ddfb;">
              <p style="margin: 0 0 0.35rem 0; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #6d28d9;">
                Prompt
              </p>
              <p id="recxr-active-stop-prompt" style="margin: 0; color: #4b5563;">
                Prompt text will appear here when an active stop is detected.
              </p>
            </div>
            <div style="margin-top: 0.9rem; padding: 0.85rem 0.95rem; border-radius: 14px; background: #fff7ed; border: 1px solid #fed7aa;">
              <p style="margin: 0 0 0.35rem 0; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #c2410c;">
                Temp Stop Mapping Debug
              </p>
              <p id="recxr-active-stop-debug-video-mode" style="margin: 0 0 0.2rem 0; font-size: 0.8rem; line-height: 1.35; color: #7c2d12;">
                raw videoMode: unknown
              </p>
              <p id="recxr-active-stop-debug-standard" style="margin: 0 0 0.2rem 0; font-size: 0.8rem; line-height: 1.35; color: #7c2d12;">
                standardVideo playbackId exists: no
              </p>
              <p id="recxr-active-stop-debug-guide" style="margin: 0 0 0.2rem 0; font-size: 0.8rem; line-height: 1.35; color: #7c2d12;">
                arGuideVideo playbackId exists: no
              </p>
              <p id="recxr-active-stop-debug-legacy" style="margin: 0 0 0.2rem 0; font-size: 0.8rem; line-height: 1.35; color: #7c2d12;">
                legacy video playbackId exists: no
              </p>
              <p id="recxr-active-stop-debug-resolved" style="margin: 0; font-size: 0.8rem; line-height: 1.35; color: #7c2d12;">
                resolved mapped mode: unknown
              </p>
            </div>
            <div id="recxr-active-stop-video" style="display: none; margin-top: 1rem;">
              <video
                id="recxr-active-stop-player"
                controls
                playsinline
                preload="metadata"
                style="display: block; width: 100%; max-width: 720px; border-radius: 16px; background: #000;"
              >
                <source id="recxr-active-stop-source" src="" type="application/x-mpegURL" />
                Your browser does not support HTML5 video playback.
              </video>
            </div>
          </div>

          <aside style="padding: 1.1rem; border-radius: 16px; border: 1px solid #e5e7eb; background: rgba(255,255,255,0.88);">
            <p style="margin: 0 0 0.35rem 0; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #0f766e;">
              Next Stop
            </p>
            <h3 id="recxr-next-stop-name" style="margin: 0 0 0.5rem 0; font-size: 1.15rem;">Waiting for route context</h3>
            <p id="recxr-next-stop-description" style="margin: 0 0 0.75rem 0; color: #52525b; line-height: 1.7;">
              Once a current stop is identified, the next moment in the sequence will appear here.
            </p>
            <p id="recxr-next-stop-distance" style="margin: 0 0 0.4rem 0; color: #555;">Distance: unavailable</p>
            <p id="recxr-next-stop-status" style="margin: 0; color: #0f766e; font-weight: 600;">Route progression not available yet.</p>
          </aside>
        </div>
      </div>
    </div>
  </section>

  {experienceStops.length > 0 && (
    <section style="padding: 0 0 2rem 0;">
      <div style="max-width: 900px; padding: 1.25rem; border: 1px solid #ece7f4; border-radius: 16px; background: #faf8fd;">
        <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">Pilot Route</h2>
        <p style="margin: 0; color: #555; line-height: 1.7;">
          This route currently includes {experienceStops.length} stop{experienceStops.length === 1 ? "" : "s"}. Each stop can carry a short description, a place-based prompt, and an optional Mux video so the NCMA walk feels authored rather than generic.
        </p>
      </div>
    </section>
  )}

  <RecxrArGuide client:load />
  <RecxrImageTargetGuide client:load />

  {body.length > 0 && (
    <section style="padding: 0 0 2rem 0;">
      <div style="max-width: 900px; line-height: 1.7;">
        <PortableText value={body} />
      </div>
    </section>
  )}

  {(guideVideoUrl || fallbackVideoUrl) && (
    <section style="padding: 0 0 2rem 0;">
      <div style="max-width: 900px;">
        <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">Guide Media</h2>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          {guideVideoUrl && (
            <a
              href={guideVideoUrl}
              target="_blank"
              rel="noreferrer"
              style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #222; text-decoration: none; color: #fff; background: #222; border-radius: 999px;"
            >
              Open Guide Video
            </a>
          )}
          {fallbackVideoUrl && (
            <a
              href={fallbackVideoUrl}
              target="_blank"
              rel="noreferrer"
              style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #ccc; text-decoration: none; color: #222; background: #fff; border-radius: 999px;"
            >
              Open Fallback Video
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  {safetyNotes.length > 0 && (
    <section style="padding: 0 0 2rem 0;">
      <div style="max-width: 900px; line-height: 1.7;">
        <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">Safety Notes</h2>
        <PortableText value={safetyNotes} />
      </div>
    </section>
  )}

  <section style="padding: 0 0 3rem 0;">
    <div style="max-width: 900px;">
      <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">Experience Stops</h2>

      {experienceStops.length > 0 ? (
        <div style="display: grid; gap: 1rem;">
          {experienceStops.map((stop, index) => (
              <article
                data-stop-index={stop.index}
                style="padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; background: #fff;"
              >
                <div style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: start; flex-wrap: wrap; margin-bottom: 0.75rem;">
                  <div>
                    <p style="margin: 0 0 0.35rem 0; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #7c3aed;">
                      Stop {index + 1}
                    </p>
                    <h3 style="margin: 0; line-height: 1.2;">{stop?.title || "Untitled Stop"}</h3>
                  </div>
                  <p
                    data-stop-role={stop.index}
                    style="margin: 0; padding: 0.45rem 0.8rem; border-radius: 999px; background: #f4f4f5; color: #52525b; font-size: 0.85rem; font-weight: 700;"
                  >
                    Along the route
                  </p>
                </div>

                <p style="margin: 0 0 0.75rem 0; color: #555; font-size: 0.95rem;">
                  {typeof stop.order === "number" ? `Route order ${stop.order}` : `Route order ${index + 1}`}
                </p>

                {stop?.description && <p style="margin: 0 0 0.75rem 0; line-height: 1.7;">{stop.description}</p>}

                {stop?.promptText && (
                  <div style="margin: 0 0 0.75rem 0; padding: 0.9rem 1rem; border-radius: 12px; background: #f8f5ff; border: 1px solid #ece3ff;">
                    <p style="margin: 0 0 0.3rem 0; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #6d28d9;">
                      Prompt Text
                    </p>
                    <p style="margin: 0; line-height: 1.7;"><strong>{stop.promptText}</strong></p>
                  </div>
                )}

                <p style="margin: 0 0 0.75rem 0; color: #555; line-height: 1.7;">
                  <strong>Debug:</strong> {stop.latitude}, {stop.longitude}
                  {typeof stop.activationRadiusMeters === "number" ? ` • Radius ${stop.activationRadiusMeters}m` : ""}
                </p>
                <p data-stop-debug={stop.index} style="margin: 0 0 0.75rem 0; color: #555; font-weight: 600;">
                  Distance: unavailable • Status: locked
                </p>

                {stop.standardHlsUrl ? (
                  <div style="margin-top: 1rem;">
                    <video
                      controls
                      playsinline
                      preload="metadata"
                      style="display: block; width: 100%; max-width: 720px; border-radius: 16px; background: #000;"
                    >
                      <source src={stop.standardHlsUrl} type="application/x-mpegURL" />
                      Your browser does not support HTML5 video playback.
                    </video>
                    <p style="margin: 0.5rem 0 0 0; color: #555;">
                      Standard playback ID: {stop.standardPlaybackId || stop.playbackId}
                      {stop.videoMode === "packedAlpha" && stop.arGuidePlaybackId ? ` • AR guide playback ID: ${stop.arGuidePlaybackId}` : ""}
                    </p>
                  </div>
                ) : (
                  <p style="margin: 0; color: #555;">No standard video uploaded for this stop yet.</p>
                )}
              </article>
          ))}
        </div>
      ) : (
        <p style="margin: 0; color: #555;">No experience stops have been added to this RecXR site yet.</p>
      )}
    </div>
  </section>
</Layout>

<script define:vars={{ experienceStops }} is:inline>
  const geolocateButton = document.getElementById('recxr-geolocate');
  const geolocateStatus = document.getElementById('recxr-geolocate-status');
  const geolocateCoords = document.getElementById('recxr-geolocate-coords');
  const activeStopName = document.getElementById('recxr-active-stop-name');
  const activeStopSequence = document.getElementById('recxr-active-stop-sequence');
  const activeStopDescription = document.getElementById('recxr-active-stop-description');
  const activeStopDistance = document.getElementById('recxr-active-stop-distance');
  const activeStopStatus = document.getElementById('recxr-active-stop-status');
  const activeStopPrompt = document.getElementById('recxr-active-stop-prompt');
  const activeStopDebugVideoMode = document.getElementById('recxr-active-stop-debug-video-mode');
  const activeStopDebugStandard = document.getElementById('recxr-active-stop-debug-standard');
  const activeStopDebugGuide = document.getElementById('recxr-active-stop-debug-guide');
  const activeStopDebugLegacy = document.getElementById('recxr-active-stop-debug-legacy');
  const activeStopDebugResolved = document.getElementById('recxr-active-stop-debug-resolved');
  const activeStopVideo = document.getElementById('recxr-active-stop-video');
  const activeStopPlayer = document.getElementById('recxr-active-stop-player');
  const activeStopSource = document.getElementById('recxr-active-stop-source');
  const nextStopName = document.getElementById('recxr-next-stop-name');
  const nextStopDescription = document.getElementById('recxr-next-stop-description');
  const nextStopDistance = document.getElementById('recxr-next-stop-distance');
  const nextStopStatus = document.getElementById('recxr-next-stop-status');
  let geolocationWatchId = null;
  let lastKnownPosition = null;

  function updateActiveStopMappingDebug(stop) {
    if (activeStopDebugVideoMode) {
      activeStopDebugVideoMode.textContent = `raw videoMode: ${stop?.videoMode ?? 'unknown'}`;
    }
    if (activeStopDebugStandard) {
      activeStopDebugStandard.textContent = `standardVideo playbackId exists: ${stop?.standardPlaybackId ? 'yes' : 'no'}`;
    }
    if (activeStopDebugGuide) {
      activeStopDebugGuide.textContent = `arGuideVideo playbackId exists: ${stop?.arGuidePlaybackId ? 'yes' : 'no'}`;
    }
    if (activeStopDebugLegacy) {
      const legacyPlaybackId = stop?.video?.asset?.playbackId || stop?.playbackId;
      activeStopDebugLegacy.textContent = `legacy video playbackId exists: ${legacyPlaybackId ? 'yes' : 'no'}`;
    }
    if (activeStopDebugResolved) {
      activeStopDebugResolved.textContent = `resolved mapped mode: ${stop?.videoMode ?? 'unknown'}`;
    }
  }

  function toRadians(value) {
    return (value * Math.PI) / 180;
  }

  function distanceInMeters(fromLat, fromLng, toLat, toLng) {
    const earthRadius = 6371000;
    const dLat = toRadians(toLat - fromLat);
    const dLng = toRadians(toLng - fromLng);
    const startLat = toRadians(fromLat);
    const endLat = toRadians(toLat);
    const haversine =
      Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos(startLat) * Math.cos(endLat) * Math.sin(dLng / 2) * Math.sin(dLng / 2);

    return 2 * earthRadius * Math.atan2(Math.sqrt(haversine), Math.sqrt(1 - haversine));
  }

  function formatDistance(distance) {
    if (distance == null || Number.isNaN(distance)) return 'unavailable';
    return distance < 1000 ? `${Math.round(distance)} m` : `${(distance / 1000).toFixed(2)} km`;
  }

  function findNextStop(stops, currentStop) {
    if (!stops?.length || !currentStop) return null;

    return stops.find((stop) => stop.index !== currentStop.index && (stop.order ?? stop.index) > (currentStop.order ?? currentStop.index)) || null;
  }

  function updateNextStopPanel(nextStop) {
    if (!nextStop) {
      if (nextStopName) nextStopName.textContent = 'No later stop configured';
      if (nextStopDescription) nextStopDescription.textContent = 'This appears to be the final moment in the current route, or later stops have not been added yet.';
      if (nextStopDistance) nextStopDistance.textContent = 'Distance: unavailable';
      if (nextStopStatus) nextStopStatus.textContent = 'Add another stop in Sanity to extend the journey.';
      return;
    }

    if (nextStopName) nextStopName.textContent = nextStop.title || 'Untitled next stop';
    if (nextStopDescription) {
      nextStopDescription.textContent =
        nextStop.description || nextStop.promptText || 'Add a short description or prompt so the transition into this stop feels intentional.';
    }
    if (nextStopDistance) {
      nextStopDistance.textContent = `Distance: ${formatDistance(nextStop.distanceMeters)}`;
    }
    if (nextStopStatus) {
      nextStopStatus.textContent = `Up next in the route${nextStop.promptText ? `: ${nextStop.promptText}` : '.'}`;
    }
  }

  function updateStopCards(nearestStop, nextStop) {
    const cards = document.querySelectorAll('[data-stop-index]');
    const debugRows = document.querySelectorAll('[data-stop-debug]');
    const roleBadges = document.querySelectorAll('[data-stop-role]');

    cards.forEach((card) => {
      const index = Number(card.getAttribute('data-stop-index'));
      const isActive = nearestStop && index === nearestStop.index;
      const isNext = nextStop && index === nextStop.index;
      card.style.borderColor = isActive ? '#171227' : '#e5e5e5';
      card.style.background = isActive ? '#faf7ff' : isNext ? '#f7fffc' : '#fff';
      card.style.boxShadow = isActive ? '0 12px 32px rgba(23, 18, 39, 0.08)' : 'none';
    });

    roleBadges.forEach((badge) => {
      const index = Number(badge.getAttribute('data-stop-role'));
      const isActive = nearestStop && index === nearestStop.index;
      const isNext = nextStop && index === nextStop.index;

      if (isActive) {
        badge.textContent = 'Current stop';
        badge.style.background = '#ede9fe';
        badge.style.color = '#5b21b6';
      } else if (isNext) {
        badge.textContent = 'Next stop';
        badge.style.background = '#ccfbf1';
        badge.style.color = '#115e59';
      } else {
        badge.textContent = 'Along the route';
        badge.style.background = '#f4f4f5';
        badge.style.color = '#52525b';
      }
    });

    debugRows.forEach((row) => {
      const index = Number(row.getAttribute('data-stop-debug'));
      const stop = nearestStop?.allStops?.find((entry) => entry.index === index) || experienceStops.find((entry) => entry.index === index);
      if (!stop) return;
      const unlocked = Boolean(stop.isUnlocked);
      const label = nearestStop && stop.index === nearestStop.index ? 'Current stop' : nextStop && stop.index === nextStop.index ? 'Next stop' : 'Route stop';
      row.textContent = `${label} • Distance: ${formatDistance(stop.distanceMeters)} • Status: ${unlocked ? 'unlocked' : 'locked'}`;
    });
  }

  function logGeofence(message, details) {
    console.log(`[RecXR][Geofence] ${message}`, details ?? {});
  }

  function updateActiveStop(userLatitude, userLongitude, accuracy) {
    lastKnownPosition = { latitude: userLatitude, longitude: userLongitude, accuracy };
    if (!experienceStops.length) {
      if (activeStopName) activeStopName.textContent = 'Nearest stop: no experience stops configured.';
      updateActiveStopMappingDebug(null);
      updateNextStopPanel(null);
      return;
    }

    const stopsWithDistance = experienceStops.map((stop) => {
      const distanceMeters = distanceInMeters(userLatitude, userLongitude, stop.latitude, stop.longitude);
      const radius = typeof stop.activationRadiusMeters === 'number' ? stop.activationRadiusMeters : 0;
      const isUnlocked = radius > 0 && distanceMeters <= radius;

      logGeofence('stop comparison', {
        stopId: stop.slug?.current || stop.slug || stop.title || stop.index,
        userLatitude,
        userLongitude,
        stopLatitude: stop.latitude,
        stopLongitude: stop.longitude,
        distanceMeters,
        activationRadiusMeters: radius,
        comparison: `${distanceMeters} <= ${radius}`,
        unlockComparisonResult: isUnlocked,
      });

      return {
        ...stop,
        distanceMeters,
        isUnlocked,
      };
    });

    const nearestStop = [...stopsWithDistance].sort((a, b) => a.distanceMeters - b.distanceMeters)[0];
    nearestStop.allStops = stopsWithDistance;
    const nextStop = findNextStop(stopsWithDistance, nearestStop);
    const hasUnlockedActiveStop = Boolean(nearestStop?.isUnlocked);

    logGeofence('active stop resolved', {
      activeStopId: nearestStop?.slug?.current || nearestStop?.slug || nearestStop?.title || nearestStop?.index,
      hasUnlockedActiveStop,
      nearestStopDistanceMeters: nearestStop?.distanceMeters,
      nearestStopRadiusMeters: nearestStop?.activationRadiusMeters,
      accuracy,
    });

    if (activeStopSequence) {
      activeStopSequence.textContent = `Stop ${nearestStop.index + 1} of ${experienceStops.length}`;
    }
    if (activeStopName) activeStopName.textContent = nearestStop.title || 'Untitled Stop';
    if (activeStopDescription) {
      activeStopDescription.textContent =
        nearestStop.description || 'Add a short stop description in Sanity to give this moment a stronger sense of place.';
    }
    if (activeStopDistance) {
      activeStopDistance.textContent = `Distance: ${formatDistance(nearestStop.distanceMeters)}${accuracy ? ` • Accuracy ±${Math.round(accuracy)}m` : ''}`;
    }
    if (activeStopStatus) {
      activeStopStatus.textContent = nearestStop.isUnlocked ? 'Unlocked on site' : 'Approaching stop';
      activeStopStatus.style.color = nearestStop.isUnlocked ? '#0f766e' : '#5b21b6';
      activeStopStatus.style.background = nearestStop.isUnlocked ? '#ccfbf1' : '#ede9fe';
    }
    if (activeStopPrompt) {
      activeStopPrompt.textContent = nearestStop.promptText || 'No prompt text is configured for the nearest stop.';
    }
    updateActiveStopMappingDebug(nearestStop);
    updateNextStopPanel(nextStop);

    if (nearestStop.isUnlocked && nearestStop.standardHlsUrl && activeStopVideo && activeStopSource && activeStopPlayer) {
      activeStopVideo.style.display = 'block';
      activeStopSource.src = nearestStop.standardHlsUrl;
      activeStopPlayer.load();
    } else if (activeStopVideo && activeStopSource && activeStopPlayer) {
      activeStopVideo.style.display = 'none';
      activeStopSource.src = '';
      activeStopPlayer.load();
    }

    const activeStop = hasUnlockedActiveStop
      ? {
          ...nearestStop,
          routeStopCount: experienceStops.length,
          nextStopDistanceMeters: typeof nextStop?.distanceMeters === "number" ? nextStop.distanceMeters : null,
          nextStopTitle: nextStop?.title || "",
        }
      : null;
    window.dispatchEvent(new CustomEvent('recxr-active-stop', { detail: activeStop }));

    updateStopCards(nearestStop, nextStop);
  }

  function handlePositionUpdate(position) {
    const { latitude, longitude, accuracy } = position.coords;
    if (geolocateStatus) geolocateStatus.textContent = 'Location access granted.';
    if (geolocateCoords) {
      geolocateCoords.textContent = `Your coordinates: ${latitude.toFixed(6)}, ${longitude.toFixed(6)} (accuracy ±${Math.round(accuracy)}m)`;
    }
    logGeofence('position update', {
      latitude,
      longitude,
      accuracy,
    });
    updateActiveStop(latitude, longitude, accuracy);
  }

  function handlePositionError(error) {
    if (geolocateStatus) geolocateStatus.textContent = `Location request failed: ${error.message}`;
    if (geolocateCoords) geolocateCoords.textContent = '';
    updateActiveStopMappingDebug(null);
    updateNextStopPanel(null);
    updateStopCards();
    logGeofence('position error', {
      code: error?.code,
      message: error?.message,
    });
  }

  geolocateButton?.addEventListener('click', () => {
    if (!navigator.geolocation) {
      if (geolocateStatus) geolocateStatus.textContent = 'Geolocation is not supported in this browser.';
      return;
    }

    if (geolocateStatus) geolocateStatus.textContent = 'Requesting your location...';

    const geolocationOptions = {
      enableHighAccuracy: true,
      timeout: 10000,
      maximumAge: 0,
    };

    navigator.geolocation.getCurrentPosition(handlePositionUpdate, handlePositionError, geolocationOptions);

    if (geolocationWatchId != null) {
      navigator.geolocation.clearWatch(geolocationWatchId);
    }
    geolocationWatchId = navigator.geolocation.watchPosition(handlePositionUpdate, handlePositionError, geolocationOptions);
  });
  window.dispatchEvent(new CustomEvent('recxr-active-stop', { detail: null }));
  updateNextStopPanel(null);
  updateStopCards();
</script>
