---
import { client } from "../utils/sanity-client";
import SectionLayout from "../layouts/SectionLayout.astro";
import { ABOUT_NATHAN_BASE_PATH, fetchAboutNathanSubpages, toSectionNavItems } from "../data/sectionNav";
import { PORTABLE_BODY } from "../data/portableText";

const [aboutNathanPage, aboutNathanSubpages] = await Promise.all([client.fetch(
  `*[_type == "aboutNathanPage"][0]{
    title,
    shortTitle,
    intro,
    ${PORTABLE_BODY}
  }`
), fetchAboutNathanSubpages()]);

const title = aboutNathanPage?.title ?? "About Nathan";
const intro = aboutNathanPage?.intro ?? "";
const body = aboutNathanPage?.body ?? [];
const secondaryNavItems = toSectionNavItems(aboutNathanSubpages, ABOUT_NATHAN_BASE_PATH);
---

<SectionLayout
  title={title}
  intro={intro}
  body={body}
  secondaryNavTitle="About Nathan"
  secondaryNavItems={secondaryNavItems}
  currentPath={ABOUT_NATHAN_BASE_PATH}
/>
