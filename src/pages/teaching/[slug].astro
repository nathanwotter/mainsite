---
import { client } from "../../utils/sanity-client";
import SectionLayout from "../../layouts/SectionLayout.astro";
import { fetchTeachingSubpages, TEACHING_BASE_PATH, toSectionNavItems } from "../../data/sectionNav";

export async function getStaticPaths() {
  const slugs = await client.fetch(
    `*[_type == "teachingSubpage" && defined(slug.current)]{
      "slug": slug.current
    }`
  );

  return slugs.map(({ slug }: { slug: string }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

const [teachingSubpage, teachingSubpages] = await Promise.all([
  slug
  ? client.fetch(
      `*[_type == "teachingSubpage" && slug.current == $slug][0]{
        title,
        intro,
        body
      }`,
      { slug }
    )
  : null,
  fetchTeachingSubpages()
]);

const title = teachingSubpage?.title ?? "Teaching";
const intro = teachingSubpage?.intro ?? "";
const body = teachingSubpage?.body ?? [];
const secondaryNavItems = toSectionNavItems(teachingSubpages, TEACHING_BASE_PATH);
---

<SectionLayout
  title={title}
  intro={intro}
  body={body}
  secondaryNavTitle="Teaching"
  secondaryNavItems={secondaryNavItems}
  currentPath={`${TEACHING_BASE_PATH}/${slug}`}
/>
