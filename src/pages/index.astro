---
import Layout from "../layouts/Layout.astro";
import { client } from "../utils/sanity-client";
import { PortableText } from "astro-portabletext";

const homePage = await client.fetch(`*[_type == "homePage"][0]`);

const title = homePage?.title ?? "Otter Adventures";
const intro =
  homePage?.intro ??
  "Exploring teaching, recreation futures, food, and coaching through creative, practical, and immersive work.";
const body = homePage?.body ?? [];
---

<Layout title={title}>
  <section style="padding: 2rem 0 3rem 0;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.9rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem; color: #666;">
        Welcome
      </p>

      <h1 style="font-size: clamp(2.2rem, 6vw, 4rem); line-height: 1.05; margin: 0 0 1rem 0;">
        {title}
      </h1>

      <p style="font-size: 1.15rem; line-height: 1.7; max-width: 700px; margin: 0 0 1.5rem 0;">
        {intro}
      </p>

      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem;">
        <a
          href="/recreation-futures-lab"
          style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #222; text-decoration: none; color: #fff; background: #222; border-radius: 999px;"
        >
          Explore Recreation Futures Lab
        </a>

        <a
          href="/teaching"
          style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #ccc; text-decoration: none; color: #222; background: #fff; border-radius: 999px;"
        >
          View Teaching
        </a>
      </div>
    </div>
  </section>

  <section style="padding: 1rem 0 3rem 0;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">Explore Otter Adventures</h2>

      <div
        style="
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
          gap: 1rem;
        "
      >
        <a
          href="/teaching"
          style="display: block; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; text-decoration: none; color: inherit;"
        >
          <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Teaching</h3>
          <p style="margin: 0; line-height: 1.6; color: #555;">
            Courses, learning resources, and ideas related to recreation, play, and experiential education.
          </p>
        </a>

        <a
          href="/recreation-futures-lab"
          style="display: block; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; text-decoration: none; color: inherit;"
        >
          <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Recreation Futures Lab</h3>
          <p style="margin: 0; line-height: 1.6; color: #555;">
            WebXR, digital twins, immersive media, and future-facing recreation programming.
          </p>
        </a>

        <a
          href="/food"
          style="display: block; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; text-decoration: none; color: inherit;"
        >
          <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Food</h3>
          <p style="margin: 0; line-height: 1.6; color: #555;">
            Cooking classes, food resources, maps, and cultural exploration through meals and ingredients.
          </p>
        </a>

        <a
          href="/about-nathan"
          style="display: block; padding: 1.25rem; border: 1px solid #e5e5e5; border-radius: 16px; text-decoration: none; color: inherit;"
        >
          <h3 style="margin-top: 0; margin-bottom: 0.5rem;">About Nathan</h3>
          <p style="margin: 0; line-height: 1.6; color: #555;">
            Learn more about the person, ideas, and motivations behind Otter Adventures.
          </p>
        </a>
      </div>
    </div>
  </section>

  {body.length > 0 && (
    <section style="padding: 0 0 3rem 0;">
      <div style="max-width: 900px; margin: 0 auto; line-height: 1.7;">
        <PortableText value={body} />
      </div>
    </section>
  )}
</Layout>
