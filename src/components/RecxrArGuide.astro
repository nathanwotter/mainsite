---
---

<section id="recxr-ar-launch" style="display: block; padding: 0 0 2rem 0;">
  <div style="max-width: 900px; padding: 1.25rem; border: 1px solid #171227; border-radius: 16px; background: #f8f7fb;">
    <div
      style="margin: 0 0 1rem 0; padding: 1rem; border: 2px solid #b91c1c; border-radius: 12px; background: #fef2f2;"
    >
      <p style="margin: 0 0 0.5rem 0; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #991b1b;">
        Temporary Debug Override
      </p>
      <p id="recxr-debug-mounted" style="margin: 0 0 0.35rem 0; color: #222;">Section mounted: no</p>
      <p id="recxr-debug-stop-title" style="margin: 0 0 0.35rem 0; color: #222;">Active stop title: none</p>
      <p id="recxr-debug-stop-unlocked" style="margin: 0 0 0.35rem 0; color: #222;">Active stop unlocked: no</p>
      <p id="recxr-debug-video" style="margin: 0 0 0.35rem 0; color: #222;">Active stop has usable video: no</p>
      <p id="recxr-debug-webxr" style="margin: 0 0 0.35rem 0; color: #222;">WebXR immersive-ar supported: checking</p>
      <p id="recxr-debug-camera" style="margin: 0 0 0.35rem 0; color: #222;">Camera guide supported: checking</p>
      <p id="recxr-debug-device-branch" style="margin: 0; color: #222;">Detected device branch: standard</p>
    </div>
    <div
      style="margin: 0 0 1rem 0; padding: 1rem; border: 2px solid #1d4ed8; border-radius: 12px; background: #eff6ff;"
    >
      <p style="margin: 0 0 0.5rem 0; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #1d4ed8;">
        Temporary Runtime Status
      </p>
      <p id="recxr-runtime-started" style="margin: 0 0 0.35rem 0; color: #1e3a8a;">Script started: no</p>
      <p id="recxr-runtime-completed" style="margin: 0 0 0.35rem 0; color: #1e3a8a;">Script completed: no</p>
      <p id="recxr-runtime-step" style="margin: 0 0 0.35rem 0; color: #1e3a8a;">Last successful init step: not started</p>
      <p id="recxr-runtime-error" style="margin: 0; color: #991b1b;">Caught error: none</p>
    </div>
    <h2 style="font-size: 1.25rem; margin: 0 0 0.75rem 0;">AR Launch</h2>
    <p id="recxr-ar-launch-copy" style="margin: 0 0 1rem 0;">
      Your nearest stop is unlocked. You can launch the AR guide for this stop or use the standard video player.
    </p>
    <p id="recxr-ar-capability" style="margin: 0 0 1rem 0; color: #555;">Checking AR browser capability...</p>
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <button
        id="recxr-ar-launch-button"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #171227; text-decoration: none; color: #fff; background: #171227; border-radius: 999px; cursor: pointer;"
      >
        Launch AR Guide
      </button>
      <button
        id="recxr-camera-launch-button"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #171227; text-decoration: none; color: #171227; background: #fff2d7; border-radius: 999px; cursor: pointer;"
      >
        Launch Camera Guide
      </button>
      <button
        id="recxr-standard-video-button"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #ccc; text-decoration: none; color: #222; background: #fff; border-radius: 999px; cursor: pointer;"
      >
        Watch Standard Video
      </button>
    </div>
  </div>
</section>

<div
  id="recxr-ar-overlay"
  style="display: none; position: fixed; inset: 0; z-index: 1000; background: rgba(15, 15, 20, 0.96); color: #fff; overflow: hidden;"
>
  <div
    id="recxr-ar-ui"
    style="position: relative; z-index: 2; padding: 1rem; pointer-events: auto;"
  >
    <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: start; flex-wrap: wrap; margin-bottom: 1rem;">
      <div>
        <p style="margin: 0 0 0.35rem 0; font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase; color: #d1d5db;">
          RecXR AR Mode
        </p>
        <h2 id="recxr-ar-overlay-title" style="margin: 0;">Preparing guide...</h2>
      </div>
      <button
        id="recxr-ar-close"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #fff; color: #fff; background: transparent; border-radius: 999px; cursor: pointer;"
      >
        Close AR Mode
      </button>
    </div>

    <p id="recxr-ar-overlay-copy" style="margin: 0 0 1rem 0; line-height: 1.7; color: #e5e7eb; max-width: 42rem;">
      Scan for a surface, then tap to place the guide panel. This uses true WebXR hit testing, with a simple rectangular video panel for MVP 1.
    </p>

    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem;">
      <button
        id="recxr-ar-place-guide"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #fff; color: #171227; background: #fff; border-radius: 999px; cursor: pointer;"
      >
        Tap Surface To Place
      </button>
      <button
        id="recxr-ar-reset-guide"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid rgba(255,255,255,0.5); color: #fff; background: transparent; border-radius: 999px; cursor: pointer;"
      >
        Reset Placement
      </button>
    </div>

    <p id="recxr-ar-session-status" style="margin: 0; color: #d1d5db;">
      AR session not started.
    </p>
  </div>

  <div
    id="recxr-ar-canvas"
    style="position: absolute; inset: 0; z-index: 1;"
  ></div>
</div>

<div
  id="recxr-camera-overlay"
  style="display: none; position: fixed; inset: 0; z-index: 999; background: #05070b; color: #fff; overflow: hidden;"
>
  <video
    id="recxr-camera-feed"
    autoplay
    muted
    playsinline
    style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; background: #000;"
  ></video>

  <div
    style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(5, 7, 11, 0.72), rgba(5, 7, 11, 0.08) 35%, rgba(5, 7, 11, 0.65)); pointer-events: none;"
  ></div>

  <div style="position: relative; z-index: 2; padding: 1rem; pointer-events: auto;">
    <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: start; flex-wrap: wrap; margin-bottom: 1rem;">
      <div style="max-width: 36rem;">
        <p style="margin: 0 0 0.35rem 0; font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase; color: #d1d5db;">
          RecXR Camera Guide
        </p>
        <h2 id="recxr-camera-title" style="margin: 0 0 0.5rem 0;">Preparing camera guide...</h2>
        <p id="recxr-camera-copy" style="margin: 0; line-height: 1.7; color: #e5e7eb;">
          This fallback mode keeps the guide immersive on phones that do not support WebXR AR.
        </p>
      </div>
      <button
        id="recxr-camera-close"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid #fff; color: #fff; background: transparent; border-radius: 999px; cursor: pointer;"
      >
        Close Camera Guide
      </button>
    </div>

    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem;">
      <button
        id="recxr-camera-reset"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid rgba(255,255,255,0.65); color: #171227; background: #fff; border-radius: 999px; cursor: pointer;"
      >
        Reset Panel Position
      </button>
      <button
        id="recxr-camera-standard-video"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid rgba(255,255,255,0.5); color: #fff; background: transparent; border-radius: 999px; cursor: pointer;"
      >
        Watch Standard Video
      </button>
      <button
        id="recxr-camera-place-here"
        type="button"
        style="display: inline-block; padding: 0.8rem 1.1rem; border: 1px solid rgba(255,255,255,0.5); color: #fff; background: rgba(255,255,255,0.08); border-radius: 999px; cursor: pointer;"
      >
        Place Guide Here
      </button>
    </div>

    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
      <button
        id="recxr-camera-pos-center"
        type="button"
        style="display: inline-block; padding: 0.65rem 0.95rem; border: 1px solid rgba(255,255,255,0.35); color: #fff; background: rgba(255,255,255,0.08); border-radius: 999px; cursor: pointer;"
      >
        Lower Center
      </button>
      <button
        id="recxr-camera-pos-left"
        type="button"
        style="display: inline-block; padding: 0.65rem 0.95rem; border: 1px solid rgba(255,255,255,0.35); color: #fff; background: rgba(255,255,255,0.08); border-radius: 999px; cursor: pointer;"
      >
        Lower Left
      </button>
      <button
        id="recxr-camera-pos-right"
        type="button"
        style="display: inline-block; padding: 0.65rem 0.95rem; border: 1px solid rgba(255,255,255,0.35); color: #fff; background: rgba(255,255,255,0.08); border-radius: 999px; cursor: pointer;"
      >
        Lower Right
      </button>
    </div>

    <p id="recxr-camera-status" style="margin: 0; color: #d1d5db;">
      Requesting camera access...
    </p>
  </div>

  <div
    id="recxr-camera-panel-shadow"
    style="display: none; position: absolute; left: 50%; top: 72%; width: min(52vw, 16rem); height: 1.75rem; transform: translate(-50%, -50%); z-index: 2; pointer-events: none; border-radius: 999px; background: radial-gradient(circle, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.18) 45%, rgba(0,0,0,0) 75%); filter: blur(10px); opacity: 0.8;"
  ></div>

  <div
    id="recxr-camera-panel"
    style="display: none; position: absolute; left: 50%; top: 72%; width: min(82vw, 28rem); transform: translate(-50%, -50%); z-index: 3; border-radius: 20px; overflow: hidden; border: 1px solid rgba(255,255,255,0.4); box-shadow: 0 24px 80px rgba(0,0,0,0.38), 0 0 0 1px rgba(255,255,255,0.06) inset; background: linear-gradient(180deg, rgba(23, 18, 39, 0.9), rgba(14, 18, 28, 0.82)); backdrop-filter: blur(12px); touch-action: none; transition: left 180ms ease, top 180ms ease, transform 180ms ease;"
  >
    <div
      id="recxr-camera-panel-handle"
      style="padding: 0.8rem 1rem; cursor: grab; background: rgba(255,255,255,0.08); border-bottom: 1px solid rgba(255,255,255,0.12);"
    >
      <p style="margin: 0; font-size: 0.9rem; color: #f3f4f6;">Drag guide panel</p>
    </div>
    <canvas
      id="recxr-camera-panel-canvas"
      style="display: none; width: 100%; height: auto; background: transparent;"
    ></canvas>
    <video
      id="recxr-camera-panel-video"
      controls
      playsinline
      preload="metadata"
      style="display: block; width: 100%; background: #000;"
    >
      <source id="recxr-camera-panel-source" src="" type="application/x-mpegURL" />
      Your browser does not support HTML5 video playback.
    </video>
    <video
      id="recxr-camera-panel-guide-video"
      muted
      playsinline
      preload="metadata"
      style="display: none;"
    ></video>
    <div style="padding: 1rem;">
      <p id="recxr-camera-panel-prompt" style="margin: 0; line-height: 1.7; color: #f3f4f6;">
        Prompt text will appear here when a stop is unlocked.
      </p>
      <p id="recxr-camera-visible-surface" style="margin: 0.75rem 0 0 0; font-size: 0.85rem; font-weight: 700; color: #f9a8d4;">
        Visible surface: video
      </p>
      <div style="margin-top: 0.85rem; padding: 0.85rem; border-radius: 12px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
        <p style="margin: 0 0 0.45rem 0; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #f9a8d4;">
          Temporary Surface Debug
        </p>
        <p id="recxr-camera-debug-video-mode" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">stop.videoMode: unknown</p>
        <p id="recxr-camera-debug-standard" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">standardHlsUrl present: no</p>
        <p id="recxr-camera-debug-guide" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">arGuideHlsUrl present: no</p>
        <p id="recxr-camera-debug-resolved" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">resolvedGuideMode: unknown</p>
        <p id="recxr-camera-debug-visible" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">visibleSurface: video</p>
        <p id="recxr-camera-debug-started" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">packed-alpha decode started: no</p>
        <p id="recxr-camera-debug-succeeded" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">packed-alpha decode succeeded: no</p>
        <p id="recxr-camera-debug-fallback" style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: #f3f4f6;">fallback-to-video occurred: no</p>
        <p id="recxr-camera-debug-reason" style="margin: 0; font-size: 0.85rem; color: #fca5a5;">fallback reason: none</p>
      </div>
    </div>
  </div>
</div>

<script>
  import * as THREE from 'three';

  const arLaunchSection = document.getElementById('recxr-ar-launch');
  const arLaunchCopy = document.getElementById('recxr-ar-launch-copy');
  const arCapability = document.getElementById('recxr-ar-capability');
  const arLaunchButton = document.getElementById('recxr-ar-launch-button');
  const cameraLaunchButton = document.getElementById('recxr-camera-launch-button');
  const standardVideoButton = document.getElementById('recxr-standard-video-button');
  const arOverlay = document.getElementById('recxr-ar-overlay');
  const arOverlayTitle = document.getElementById('recxr-ar-overlay-title');
  const arOverlayCopy = document.getElementById('recxr-ar-overlay-copy');
  const arCloseButton = document.getElementById('recxr-ar-close');
  const arCanvasMount = document.getElementById('recxr-ar-canvas');
  const arSessionStatus = document.getElementById('recxr-ar-session-status');
  const arResetGuideButton = document.getElementById('recxr-ar-reset-guide');
  const cameraOverlay = document.getElementById('recxr-camera-overlay');
  const cameraFeed = document.getElementById('recxr-camera-feed');
  const cameraTitle = document.getElementById('recxr-camera-title');
  const cameraCopy = document.getElementById('recxr-camera-copy');
  const cameraStatus = document.getElementById('recxr-camera-status');
  const cameraCloseButton = document.getElementById('recxr-camera-close');
  const cameraResetButton = document.getElementById('recxr-camera-reset');
  const cameraStandardVideoButton = document.getElementById('recxr-camera-standard-video');
  const cameraPlaceHereButton = document.getElementById('recxr-camera-place-here');
  const cameraPosCenterButton = document.getElementById('recxr-camera-pos-center');
  const cameraPosLeftButton = document.getElementById('recxr-camera-pos-left');
  const cameraPosRightButton = document.getElementById('recxr-camera-pos-right');
  const cameraPanelShadow = document.getElementById('recxr-camera-panel-shadow');
  const cameraPanel = document.getElementById('recxr-camera-panel');
  const cameraPanelHandle = document.getElementById('recxr-camera-panel-handle');
  const cameraPanelCanvas = document.getElementById('recxr-camera-panel-canvas');
  const cameraPanelVideo = document.getElementById('recxr-camera-panel-video');
  const cameraPanelSource = document.getElementById('recxr-camera-panel-source');
  const cameraPanelGuideVideo = document.getElementById('recxr-camera-panel-guide-video');
  const cameraPanelPrompt = document.getElementById('recxr-camera-panel-prompt');
  const cameraVisibleSurface = document.getElementById('recxr-camera-visible-surface');
  const cameraDebugVideoMode = document.getElementById('recxr-camera-debug-video-mode');
  const cameraDebugStandard = document.getElementById('recxr-camera-debug-standard');
  const cameraDebugGuide = document.getElementById('recxr-camera-debug-guide');
  const cameraDebugResolved = document.getElementById('recxr-camera-debug-resolved');
  const cameraDebugVisible = document.getElementById('recxr-camera-debug-visible');
  const cameraDebugStarted = document.getElementById('recxr-camera-debug-started');
  const cameraDebugSucceeded = document.getElementById('recxr-camera-debug-succeeded');
  const cameraDebugFallback = document.getElementById('recxr-camera-debug-fallback');
  const cameraDebugReason = document.getElementById('recxr-camera-debug-reason');
  const standardVideoContainer = document.getElementById('recxr-active-stop-video');
  const standardVideoPlayer = document.getElementById('recxr-active-stop-player');
  const debugMounted = document.getElementById('recxr-debug-mounted');
  const debugStopTitle = document.getElementById('recxr-debug-stop-title');
  const debugStopUnlocked = document.getElementById('recxr-debug-stop-unlocked');
  const debugVideo = document.getElementById('recxr-debug-video');
  const debugWebxr = document.getElementById('recxr-debug-webxr');
  const debugCamera = document.getElementById('recxr-debug-camera');
  const debugDeviceBranch = document.getElementById('recxr-debug-device-branch');
  const runtimeStarted = document.getElementById('recxr-runtime-started');
  const runtimeCompleted = document.getElementById('recxr-runtime-completed');
  const runtimeStep = document.getElementById('recxr-runtime-step');
  const runtimeError = document.getElementById('recxr-runtime-error');

  let currentActiveStop = null;
  let xrSupported = false;
  let cameraGuideSupported = false;
  let preferredMode = 'standard';
  let deviceBranch = 'standard';
  let renderer = null;
  let scene = null;
  let camera = null;
  let controller = null;
  let currentSession = null;
  let localReferenceSpace = null;
  let viewerSpace = null;
  let hitTestSource = null;
  let hitTestSourceRequested = false;
  let reticle = null;
  let videoMesh = null;
  let videoElement = null;
  let videoTexture = null;
  let panelPlaced = false;
  let cameraStream = null;
  let panelDrag = null;
  let cameraPlacementMode = false;
  let cameraGuideAnimationFrame = null;
  let cameraGuideCanvasContext = null;
  let cameraGuideBufferCanvas = null;
  let cameraGuideBufferContext = null;
  let packedAlphaDecodeStarted = false;
  let packedAlphaDecodeSucceeded = false;
  let cameraGuideFallbackToVideo = false;
  let cameraGuideFallbackReason = 'none';
  const alphaPackedVideoVertexShader = `
    varying vec2 vUv;

    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `;
  const alphaPackedVideoFragmentShader = `
    uniform sampler2D videoMap;
    varying vec2 vUv;

    float luma(vec3 color) {
      return dot(color, vec3(0.299, 0.587, 0.114));
    }

    void main() {
      vec2 colorUv = vec2(vUv.x, 0.5 + (vUv.y * 0.5));
      vec2 alphaUv = vec2(vUv.x, vUv.y * 0.5);
      vec4 colorSample = texture2D(videoMap, colorUv);
      vec4 alphaSample = texture2D(videoMap, alphaUv);
      float alpha = luma(alphaSample.rgb);

      gl_FragColor = vec4(colorSample.rgb, alpha);
    }
  `;

  function setRuntimeStep(step) {
    if (runtimeStep) {
      runtimeStep.textContent = `Last successful init step: ${step}`;
    }
  }

  function setRuntimeError(message) {
    if (runtimeError) {
      runtimeError.textContent = `Caught error: ${message || 'none'}`;
    }
  }

  function isLikelyIphone() {
    const ua = navigator.userAgent || '';
    return /iPhone|iPad|iPod/i.test(ua) || (/Macintosh/i.test(ua) && 'ontouchend' in document);
  }

  function isIphoneChrome() {
    const ua = navigator.userAgent || '';
    return /CriOS/i.test(ua) && isLikelyIphone();
  }

  function setButtonState(button, enabled) {
    if (!button) return;
    button.disabled = !enabled;
    button.style.opacity = enabled ? '1' : '0.5';
    button.style.cursor = enabled ? 'pointer' : 'not-allowed';
  }

  function getStandardVideoUrl(stop) {
    return stop?.standardHlsUrl || stop?.hlsUrl || '';
  }

  function getGuideVideoUrl(stop) {
    return stop?.arGuideHlsUrl || stop?.standardHlsUrl || stop?.hlsUrl || '';
  }

  function getResolvedGuideMode(stop) {
    if (stop?.videoMode === 'packedAlpha' && stop?.arGuideHlsUrl) {
      return 'packedAlpha';
    }

    return 'standard';
  }

  function isPackedAlphaStop(stop) {
    return getResolvedGuideMode(stop) === 'packedAlpha';
  }

  function logGuideVideoResolution(context, stop) {
    console.log(`[RecXR] ${context}`, {
      title: stop?.title || null,
      videoMode: stop?.videoMode ?? null,
      arGuideHlsUrl: stop?.arGuideHlsUrl ?? null,
      standardHlsUrl: stop?.standardHlsUrl ?? stop?.hlsUrl ?? null,
      resolvedGuideMode: getResolvedGuideMode(stop),
    });
  }

  function createVideoPanelMaterial(stop, texture) {
    if (isPackedAlphaStop(stop)) {
      return new THREE.ShaderMaterial({
        uniforms: {
          videoMap: { value: texture },
        },
        vertexShader: alphaPackedVideoVertexShader,
        fragmentShader: alphaPackedVideoFragmentShader,
        transparent: true,
        side: THREE.DoubleSide,
        depthWrite: false,
        toneMapped: false,
      });
    }

    return new THREE.MeshBasicMaterial({
      map: texture,
      transparent: true,
      side: THREE.DoubleSide,
      toneMapped: false,
    });
  }

  function setVisibleSurfaceDebugLabel(surface) {
    if (cameraVisibleSurface) {
      cameraVisibleSurface.textContent = `Visible surface: ${surface}`;
    }
    if (cameraDebugVisible) {
      cameraDebugVisible.textContent = `visibleSurface: ${surface}`;
    }
  }

  function updateCameraGuideDebug(stop) {
    if (cameraDebugVideoMode) {
      cameraDebugVideoMode.textContent = `stop.videoMode: ${stop?.videoMode ?? 'unknown'}`;
    }
    if (cameraDebugStandard) {
      cameraDebugStandard.textContent = `standardHlsUrl present: ${getStandardVideoUrl(stop) ? 'yes' : 'no'}`;
    }
    if (cameraDebugGuide) {
      cameraDebugGuide.textContent = `arGuideHlsUrl present: ${stop?.arGuideHlsUrl ? 'yes' : 'no'}`;
    }
    if (cameraDebugResolved) {
      cameraDebugResolved.textContent = `resolvedGuideMode: ${stop ? getResolvedGuideMode(stop) : 'unknown'}`;
    }
    if (cameraDebugStarted) {
      cameraDebugStarted.textContent = `packed-alpha decode started: ${packedAlphaDecodeStarted ? 'yes' : 'no'}`;
    }
    if (cameraDebugSucceeded) {
      cameraDebugSucceeded.textContent = `packed-alpha decode succeeded: ${packedAlphaDecodeSucceeded ? 'yes' : 'no'}`;
    }
    if (cameraDebugFallback) {
      cameraDebugFallback.textContent = `fallback-to-video occurred: ${cameraGuideFallbackToVideo ? 'yes' : 'no'}`;
    }
    if (cameraDebugReason) {
      cameraDebugReason.textContent = `fallback reason: ${cameraGuideFallbackReason}`;
    }
  }

  function resetCameraGuideDebugState(stop) {
    packedAlphaDecodeStarted = false;
    packedAlphaDecodeSucceeded = false;
    cameraGuideFallbackToVideo = false;
    cameraGuideFallbackReason = 'none';
    updateCameraGuideDebug(stop);
  }

  function setCameraGuideFallback(reason, stop) {
    cameraGuideFallbackToVideo = true;
    cameraGuideFallbackReason = reason;
    updateCameraGuideDebug(stop);
  }

  function showCameraGuideSurface(mode) {
    if (cameraPanelCanvas) {
      if (mode === 'packedAlpha') {
        cameraPanelCanvas.style.cssText = 'display: block !important; visibility: visible !important; opacity: 1 !important; width: 100%; height: auto; background: rgba(59, 130, 246, 0.3) !important; border: 4px solid #ff00ff !important; pointer-events: auto;';
      } else {
        cameraPanelCanvas.style.cssText = 'display: none !important; visibility: hidden !important; opacity: 0 !important; width: 100%; height: auto; background: transparent; border: 0; pointer-events: none !important;';
      }
    }

    if (cameraPanelVideo) {
      if (mode === 'standard') {
        cameraPanelVideo.style.cssText = 'display: block; visibility: visible; opacity: 1; width: 100%; background: #000; pointer-events: auto;';
      } else {
        cameraPanelVideo.style.cssText = 'display: none !important; visibility: hidden !important; opacity: 0 !important; width: 100%; background: #000; pointer-events: none !important;';
      }
    }

    if (cameraPanelGuideVideo) {
      cameraPanelGuideVideo.style.display = 'none';
    }

    setVisibleSurfaceDebugLabel(mode === 'packedAlpha' ? 'canvas' : 'video');
  }

  function stopPackedAlphaCameraRender() {
    if (cameraGuideAnimationFrame) {
      window.cancelAnimationFrame(cameraGuideAnimationFrame);
      cameraGuideAnimationFrame = null;
    }

    if (cameraPanelGuideVideo) {
      cameraPanelGuideVideo.pause();
      cameraPanelGuideVideo.removeAttribute('src');
      cameraPanelGuideVideo.load();
    }

    if (cameraPanelCanvas) {
      cameraPanelCanvas.style.display = 'none';
      if (cameraGuideCanvasContext) {
        cameraGuideCanvasContext.clearRect(0, 0, cameraPanelCanvas.width, cameraPanelCanvas.height);
      }
    }
  }

  function renderPackedAlphaFrame() {
    if (!cameraPanelGuideVideo || !cameraPanelCanvas) return;

    if (cameraPanelGuideVideo.readyState < 2 || cameraPanelGuideVideo.videoWidth === 0 || cameraPanelGuideVideo.videoHeight === 0) {
      cameraGuideAnimationFrame = window.requestAnimationFrame(renderPackedAlphaFrame);
      return;
    }

    if (!cameraGuideCanvasContext) {
      cameraGuideCanvasContext = cameraPanelCanvas.getContext('2d', { willReadFrequently: true });
    }
    if (!cameraGuideBufferCanvas) {
      cameraGuideBufferCanvas = document.createElement('canvas');
      cameraGuideBufferContext = cameraGuideBufferCanvas.getContext('2d', { willReadFrequently: true });
    }
    if (!cameraGuideCanvasContext || !cameraGuideBufferContext) {
      return;
    }

    const frameWidth = cameraPanelGuideVideo.videoWidth;
    const packedHeight = cameraPanelGuideVideo.videoHeight;
    const frameHeight = Math.floor(packedHeight / 2);

    if (frameHeight <= 0) {
      cameraGuideAnimationFrame = window.requestAnimationFrame(renderPackedAlphaFrame);
      return;
    }

    if (cameraPanelCanvas.width !== frameWidth || cameraPanelCanvas.height !== frameHeight) {
      cameraPanelCanvas.width = frameWidth;
      cameraPanelCanvas.height = frameHeight;
      cameraPanelCanvas.style.aspectRatio = `${frameWidth} / ${frameHeight}`;
    }
    if (cameraGuideBufferCanvas.width !== frameWidth || cameraGuideBufferCanvas.height !== packedHeight) {
      cameraGuideBufferCanvas.width = frameWidth;
      cameraGuideBufferCanvas.height = packedHeight;
    }

    cameraGuideBufferContext.drawImage(cameraPanelGuideVideo, 0, 0, frameWidth, packedHeight);
    const colorFrame = cameraGuideBufferContext.getImageData(0, 0, frameWidth, frameHeight);
    const alphaFrame = cameraGuideBufferContext.getImageData(0, frameHeight, frameWidth, frameHeight);
    const colorPixels = colorFrame.data;
    const alphaPixels = alphaFrame.data;

    for (let index = 0; index < colorPixels.length; index += 4) {
      colorPixels[index + 3] = Math.round(
        (alphaPixels[index] * 0.299) +
        (alphaPixels[index + 1] * 0.587) +
        (alphaPixels[index + 2] * 0.114)
      );
    }

    cameraGuideCanvasContext.clearRect(0, 0, frameWidth, frameHeight);
    cameraGuideCanvasContext.fillStyle = 'rgba(59, 130, 246, 0.3)';
    cameraGuideCanvasContext.fillRect(0, 0, frameWidth, frameHeight);
    cameraGuideCanvasContext.putImageData(colorFrame, 0, 0);
    cameraGuideCanvasContext.fillStyle = '#ff00ff';
    cameraGuideCanvasContext.font = 'bold 22px sans-serif';
    cameraGuideCanvasContext.textBaseline = 'top';
    cameraGuideCanvasContext.fillText('PACKED CANVAS MODE', 16, 14);
    cameraGuideAnimationFrame = window.requestAnimationFrame(renderPackedAlphaFrame);
  }

  async function startPackedAlphaCameraRender(stop) {
    if (!cameraPanelGuideVideo || !cameraPanelCanvas) return false;

    const guideVideoUrl = getGuideVideoUrl(stop);
    if (!guideVideoUrl) return false;
    logGuideVideoResolution('startPackedAlphaCameraRender', stop);
    packedAlphaDecodeStarted = true;
    packedAlphaDecodeSucceeded = false;
    cameraGuideFallbackToVideo = false;
    cameraGuideFallbackReason = 'none';
    updateCameraGuideDebug(stop);

    stopPackedAlphaCameraRender();
    showCameraGuideSurface('packedAlpha');

    if (cameraPanelVideo && cameraPanelSource) {
      cameraPanelVideo.pause();
      cameraPanelSource.src = '';
      cameraPanelVideo.load();
      cameraPanelVideo.style.display = 'none';
    }

    cameraPanelGuideVideo.src = guideVideoUrl;
    cameraPanelGuideVideo.crossOrigin = 'anonymous';
    cameraPanelGuideVideo.loop = true;
    cameraPanelGuideVideo.muted = true;
    cameraPanelGuideVideo.playsInline = true;
    cameraPanelGuideVideo.setAttribute('webkit-playsinline', 'true');
    cameraPanelGuideVideo.preload = 'auto';

    await cameraPanelGuideVideo.play();
    packedAlphaDecodeSucceeded = true;
    updateCameraGuideDebug(stop);
    renderPackedAlphaFrame();
    return true;
  }

  async function playCameraGuideMedia(stop) {
    const resolvedGuideMode = getResolvedGuideMode(stop);
    logGuideVideoResolution('playCameraGuideMedia', stop);
    updateCameraGuideDebug(stop);

    if (resolvedGuideMode === 'packedAlpha') {
      try {
        const started = await startPackedAlphaCameraRender(stop);
        if (started) return;
      } catch (_error) {
        setCameraGuideFallback('packed-alpha decode threw an error', stop);
      }

      if (!getStandardVideoUrl(stop)) {
        setVisibleSurfaceDebugLabel('canvas');
        if (cameraStatus) {
          cameraStatus.textContent = 'Packed-alpha decode failed and no standard fallback video is available.';
        }
        return;
      }
    }

    if (cameraPanelCanvas) {
      cameraPanelCanvas.style.display = 'none';
    }
    if (cameraPanelVideo) {
      if (resolvedGuideMode === 'packedAlpha') {
        setCameraGuideFallback('packed-alpha stop fell back to visible video', stop);
      }
      showCameraGuideSurface('standard');
      await cameraPanelVideo.play().catch(() => {});
    }
  }

  function syncCameraShadow() {
    if (!cameraPanel || !cameraPanelShadow) return;

    const left = cameraPanel.style.left || '50%';
    const top = cameraPanel.style.top || '72%';
    cameraPanelShadow.style.left = left;
    cameraPanelShadow.style.top = top;
    cameraPanelShadow.style.display = cameraPanel.style.display === 'none' ? 'none' : 'block';
  }

  function setCameraPlacementMode(enabled) {
    cameraPlacementMode = enabled;
    if (cameraPlaceHereButton) {
      cameraPlaceHereButton.textContent = enabled ? 'Tap Anywhere To Place' : 'Place Guide Here';
      cameraPlaceHereButton.style.background = enabled ? '#fff' : 'rgba(255,255,255,0.08)';
      cameraPlaceHereButton.style.color = enabled ? '#171227' : '#fff';
    }
    if (cameraStatus && enabled) {
      cameraStatus.textContent = 'Tap anywhere on the camera view to place the guide panel.';
    }
  }

  function setCameraPanelPosition(left, top, { center = false, smooth = true } = {}) {
    if (!cameraPanel) return;

    cameraPanel.style.transition = smooth ? 'left 180ms ease, top 180ms ease, transform 180ms ease' : 'none';
    cameraPanel.style.left = left;
    cameraPanel.style.top = top;
    cameraPanel.style.transform = center ? 'translate(-50%, -50%)' : 'none';
    syncCameraShadow();
  }

  function applyPresetPlacement(position) {
    if (!cameraPanel) return;

    if (position === 'left') {
      setCameraPanelPosition('22%', '74%', { center: true });
    } else if (position === 'right') {
      setCameraPanelPosition('78%', '74%', { center: true });
    } else {
      setCameraPanelPosition('50%', '72%', { center: true });
    }

    if (cameraStatus) {
      cameraStatus.textContent = `Guide panel moved to ${position === 'center' ? 'lower center' : `lower ${position}`}.`;
    }
  }

  function updateDebugPanel(stop) {
    const hasVideo = Boolean(getStandardVideoUrl(stop) || getGuideVideoUrl(stop));
    const isUnlocked = Boolean(stop?.isUnlocked);
    if (debugMounted) {
      debugMounted.textContent = 'Section mounted: yes';
    }
    if (debugStopTitle) {
      debugStopTitle.textContent = `Active stop title: ${stop?.title || 'none'}`;
    }
    if (debugStopUnlocked) {
      debugStopUnlocked.textContent = `Active stop unlocked: ${isUnlocked ? 'yes' : 'no'}`;
    }
    if (debugVideo) {
      debugVideo.textContent = `Active stop has usable video: ${hasVideo ? 'yes' : 'no'}`;
    }
    if (debugWebxr) {
      debugWebxr.textContent = `WebXR immersive-ar supported: ${xrSupported ? 'yes' : 'no'}`;
    }
    if (debugCamera) {
      debugCamera.textContent = `Camera guide supported: ${cameraGuideSupported ? 'yes' : 'no'}`;
    }
    if (debugDeviceBranch) {
      debugDeviceBranch.textContent = `Detected device branch: ${deviceBranch}`;
    }
  }

  async function updateArCapabilityMessage() {
    if (!arCapability) return;

    const isIphone = isLikelyIphone();
    const iphoneChrome = isIphoneChrome();
    cameraGuideSupported = Boolean(navigator.mediaDevices?.getUserMedia) || isIphone;

    if (!('xr' in navigator) || !navigator.xr?.isSessionSupported) {
      xrSupported = false;
      deviceBranch = iphoneChrome
        ? 'iphone-chrome-camera'
        : isIphone
          ? 'iphone-safari-camera'
          : cameraGuideSupported
            ? 'camera-fallback'
            : 'standard-fallback';
      preferredMode = cameraGuideSupported ? 'camera' : 'standard';
      arCapability.textContent = cameraGuideSupported
        ? 'This phone does not expose WebXR immersive AR here, so RecXR will offer Camera Guide mode with your unlocked stop video.'
        : 'This browser does not support WebXR or camera guide mode. Use the standard video fallback.';
      updateDebugPanel(currentActiveStop);
      return;
    }

    try {
      xrSupported = isIphone ? false : await navigator.xr.isSessionSupported('immersive-ar');
      if (xrSupported) {
        deviceBranch = 'webxr-ar';
        preferredMode = 'webxr';
        arCapability.textContent = isLikelyIphone()
          ? 'This device exposes WebXR immersive AR, and Camera Guide is also available if you prefer the lighter fallback.'
          : 'WebXR immersive AR is available. Launch AR Guide to place a video panel on a detected surface, or use the other fallback modes.';
      } else {
        deviceBranch = iphoneChrome
          ? 'iphone-chrome-camera'
          : isIphone
            ? 'iphone-safari-camera'
            : cameraGuideSupported
              ? 'camera-fallback'
              : 'standard-fallback';
        preferredMode = cameraGuideSupported ? 'camera' : 'standard';
        arCapability.textContent = cameraGuideSupported
          ? 'WebXR immersive AR is not available on this phone, so RecXR will offer Camera Guide mode with your unlocked stop video.'
          : 'This browser does not currently support immersive-ar. Use the standard video fallback.';
      }
    } catch (_error) {
      xrSupported = false;
      deviceBranch = iphoneChrome
        ? 'iphone-chrome-camera'
        : isIphone
          ? 'iphone-safari-camera'
          : cameraGuideSupported
            ? 'camera-fallback'
            : 'standard-fallback';
      preferredMode = cameraGuideSupported ? 'camera' : 'standard';
      arCapability.textContent = cameraGuideSupported
        ? 'AR capability could not be confirmed, so Camera Guide mode will be used instead.'
        : 'AR capability could not be confirmed. Use the standard video fallback.';
    }

    updateDebugPanel(currentActiveStop);
  }

  // WebXR path: keep this renderer lightweight and focused on hit-testing plus a simple video plane.
  function ensureThreeScene() {
    if (renderer) return;

    renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, preserveDrawingBuffer: false });
    renderer.xr.enabled = true;
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(window.innerWidth, window.innerHeight);
    arCanvasMount?.appendChild(renderer.domElement);

    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera();

    const light = new THREE.HemisphereLight(0xffffff, 0xbbbbff, 1.5);
    scene.add(light);

    reticle = new THREE.Mesh(
      new THREE.RingGeometry(0.08, 0.1, 32).rotateX(-Math.PI / 2),
      new THREE.MeshBasicMaterial({ color: 0x00d4aa })
    );
    reticle.matrixAutoUpdate = false;
    reticle.visible = false;
    scene.add(reticle);

    controller = renderer.xr.getController(0);
    controller.addEventListener('select', onSelect);
    scene.add(controller);

    window.addEventListener('resize', () => {
      if (!renderer || !camera) return;
      renderer.setSize(window.innerWidth, window.innerHeight);
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
    });
  }

  function disposeVideoPanel() {
    if (videoMesh && scene) {
      scene.remove(videoMesh);
      videoMesh.geometry.dispose();
      videoMesh.material.dispose();
      videoMesh = null;
    }

    if (videoTexture) {
      videoTexture.dispose();
      videoTexture = null;
    }

    if (videoElement) {
      videoElement.pause();
      videoElement.src = '';
      videoElement.load();
      videoElement = null;
    }
  }

  function createVideoPanel(stop) {
    disposeVideoPanel();

    const guideVideoUrl = getGuideVideoUrl(stop);
    if (!scene || !guideVideoUrl) return;

    videoElement = document.createElement('video');
    videoElement.src = guideVideoUrl;
    videoElement.crossOrigin = 'anonymous';
    videoElement.loop = true;
    videoElement.muted = true;
    videoElement.playsInline = true;
    videoElement.setAttribute('webkit-playsinline', 'true');
    videoElement.preload = 'auto';

    videoTexture = new THREE.VideoTexture(videoElement);
    videoTexture.colorSpace = THREE.SRGBColorSpace;
    videoTexture.minFilter = THREE.LinearFilter;
    videoTexture.magFilter = THREE.LinearFilter;
    videoTexture.generateMipmaps = false;

    const geometry = new THREE.PlaneGeometry(1.2, 0.675);
    const material = createVideoPanelMaterial(stop, videoTexture);
    videoMesh = new THREE.Mesh(geometry, material);
    videoMesh.visible = false;
    scene.add(videoMesh);
    panelPlaced = false;
  }

  function placeVideoPanel() {
    if (!reticle?.visible || !videoMesh || !camera || !renderer) return;

    const position = new THREE.Vector3();
    const quaternion = new THREE.Quaternion();
    const scale = new THREE.Vector3();
    reticle.matrix.decompose(position, quaternion, scale);

    videoMesh.position.copy(position);
    videoMesh.position.y += 0.45;

    const xrCamera = renderer.xr.getCamera(camera);
    const cameraWorldPosition = new THREE.Vector3();
    xrCamera.getWorldPosition(cameraWorldPosition);
    videoMesh.lookAt(cameraWorldPosition.x, videoMesh.position.y, cameraWorldPosition.z);
    videoMesh.visible = true;
    panelPlaced = true;

    videoElement?.play?.().catch(() => {});
    if (arSessionStatus) {
      arSessionStatus.textContent = 'Guide panel placed. Move around the panel and use the video as your on-site guide.';
    }
  }

  function onSelect() {
    if (!panelPlaced) {
      placeVideoPanel();
    }
  }

  function resetCameraPanelPosition() {
    applyPresetPlacement('center');
  }

  function stopCameraGuide() {
    stopPackedAlphaCameraRender();

    if (cameraStream) {
      cameraStream.getTracks().forEach((track) => track.stop());
      cameraStream = null;
    }

    if (cameraFeed) {
      cameraFeed.srcObject = null;
    }

    if (cameraPanelVideo && cameraPanelSource) {
      cameraPanelVideo.pause();
      cameraPanelSource.src = '';
      cameraPanelVideo.load();
    }
    showCameraGuideSurface('standard');

    if (cameraPanel) {
      cameraPanel.style.display = 'none';
    }
    if (cameraPanelShadow) {
      cameraPanelShadow.style.display = 'none';
    }

    if (cameraOverlay) {
      cameraOverlay.style.display = 'none';
    }

    if (cameraStatus) {
      cameraStatus.textContent = 'Camera guide closed.';
    }
  }

  // Camera Guide path: for iPhone and unsupported browsers, use live camera plus a draggable guide panel.
  async function startCameraGuide(stop) {
    const guideVideoUrl = getGuideVideoUrl(stop);
    if (!guideVideoUrl || !cameraGuideSupported || !cameraOverlay || !cameraFeed) return;
    const resolvedGuideMode = getResolvedGuideMode(stop);
    logGuideVideoResolution('startCameraGuide', stop);
    resetCameraGuideDebugState(stop);

    await endArSession().catch(() => {});
    stopCameraGuide();

    if (cameraTitle) {
      cameraTitle.textContent = stop.title || 'RecXR Camera Guide';
    }
    if (cameraCopy) {
      cameraCopy.textContent = stop.promptText || 'Use the live camera as context and drag the guide panel until it sits naturally in your view.';
    }
    if (cameraPanelPrompt) {
      cameraPanelPrompt.textContent = stop.promptText || 'Move the guide panel around the screen to simulate on-site placement while we prepare full AR support.';
    }
    if (resolvedGuideMode === 'packedAlpha') {
      if (cameraPanelSource && cameraPanelVideo) {
        cameraPanelVideo.pause();
        cameraPanelSource.src = '';
        cameraPanelVideo.load();
      }
      showCameraGuideSurface('packedAlpha');
    } else if (cameraPanelSource && cameraPanelVideo) {
      const standardVideoUrl = getStandardVideoUrl(stop);
      cameraPanelSource.src = standardVideoUrl;
      cameraPanelVideo.load();
      showCameraGuideSurface('standard');
    }
    updateCameraGuideDebug(stop);
    if (cameraPanel) {
      cameraPanel.style.display = 'block';
      resetCameraPanelPosition();
    }
    if (cameraPanelShadow) {
      cameraPanelShadow.style.display = 'block';
      syncCameraShadow();
    }
    if (cameraOverlay) {
      cameraOverlay.style.display = 'block';
    }
    if (cameraStatus) {
      cameraStatus.textContent = 'Requesting rear camera access...';
    }

    try {
      if (navigator.mediaDevices?.getUserMedia) {
        cameraStream = await navigator.mediaDevices.getUserMedia({
          audio: false,
          video: {
            facingMode: { ideal: 'environment' },
          },
        });

        cameraFeed.srcObject = cameraStream;
        await cameraFeed.play();
        await playCameraGuideMedia(stop);

        if (cameraStatus) {
          cameraStatus.textContent = 'Camera Guide is live. Drag the panel to line it up with your surroundings.';
        }
      } else {
        await playCameraGuideMedia(stop);
        if (cameraStatus) {
          cameraStatus.textContent = 'Camera access is limited here, but the guide panel is still available as a fullscreen fallback for iPhone testing.';
        }
      }
    } catch (error) {
      await playCameraGuideMedia(stop);
      if (cameraStatus) {
        cameraStatus.textContent = `Camera access failed, so RecXR is showing the fullscreen guide panel instead: ${error instanceof Error ? error.message : 'Unknown error'}`;
      }
    }
  }

  function resetPlacement() {
    panelPlaced = false;
    if (videoMesh) {
      videoMesh.visible = false;
    }
    if (arSessionStatus) {
      arSessionStatus.textContent = 'Move your device to detect a surface, then tap to place the guide panel.';
    }
  }

  async function startArSession(stop) {
    if (!xrSupported || !getGuideVideoUrl(stop) || !navigator.xr) return;

    stopCameraGuide();
    ensureThreeScene();
    createVideoPanel(stop);

    try {
      currentSession = await navigator.xr.requestSession('immersive-ar', {
        requiredFeatures: ['hit-test'],
        optionalFeatures: ['dom-overlay'],
        domOverlay: { root: arOverlay },
      });
    } catch (error) {
      if (arSessionStatus) {
        arSessionStatus.textContent = `Unable to start AR session: ${error instanceof Error ? error.message : 'Unknown error'}`;
      }
      return;
    }

    currentSession.addEventListener('end', onSessionEnd);
    await renderer.xr.setSession(currentSession);

    localReferenceSpace = await currentSession.requestReferenceSpace('local');
    viewerSpace = await currentSession.requestReferenceSpace('viewer');
    hitTestSource = await currentSession.requestHitTestSource({ space: viewerSpace });
    hitTestSourceRequested = true;

    if (arOverlay) {
      arOverlay.style.display = 'block';
    }
    if (arOverlayTitle) {
      arOverlayTitle.textContent = stop.title || 'RecXR Guide';
    }
    if (arOverlayCopy) {
      arOverlayCopy.textContent = stop.promptText || 'Move your device to detect a surface, then tap to place the guide panel.';
    }
    if (arSessionStatus) {
      arSessionStatus.textContent = 'Scanning for a surface...';
    }

    renderer.setAnimationLoop((time, frame) => {
      if (frame && hitTestSource && localReferenceSpace && reticle) {
        const hitTestResults = frame.getHitTestResults(hitTestSource);

        if (!panelPlaced && hitTestResults.length > 0) {
          const hit = hitTestResults[0];
          const pose = hit.getPose(localReferenceSpace);
          if (pose) {
            reticle.visible = true;
            reticle.matrix.fromArray(pose.transform.matrix);
            if (arSessionStatus) {
              arSessionStatus.textContent = 'Surface detected. Tap the screen to place the guide panel.';
            }
          }
        } else {
          reticle.visible = false;
        }
      }

      renderer.render(scene, camera);
    });
  }

  async function endArSession() {
    if (currentSession) {
      await currentSession.end();
    } else {
      onSessionEnd();
    }
  }

  function onSessionEnd() {
    if (hitTestSource) {
      hitTestSource.cancel();
      hitTestSource = null;
    }

    hitTestSourceRequested = false;
    localReferenceSpace = null;
    viewerSpace = null;
    currentSession = null;

    if (renderer) {
      renderer.setAnimationLoop(null);
    }

    if (reticle) {
      reticle.visible = false;
    }

    disposeVideoPanel();

    if (arOverlay) {
      arOverlay.style.display = 'none';
    }
    if (arSessionStatus) {
      arSessionStatus.textContent = 'AR session ended.';
    }
  }

  function updateLaunchUi(stop) {
    currentActiveStop = stop || null;

    if (!arLaunchSection || !arLaunchCopy) return;

    const hasStandardVideo = Boolean(getStandardVideoUrl(stop));
    const hasGuideVideo = Boolean(getGuideVideoUrl(stop));
    const isUnlocked = Boolean(stop?.isUnlocked);
    const canLaunchAr = Boolean(isUnlocked && hasGuideVideo && xrSupported);
    const canLaunchCamera = Boolean(isUnlocked && hasGuideVideo && cameraGuideSupported);

    // Temporary debug override: keep the launcher visible so we can inspect capability and stop state.
    arLaunchSection.style.display = 'block';
    if (isUnlocked) {
      if (hasGuideVideo || hasStandardVideo) {
        if (canLaunchAr && canLaunchCamera) {
          arLaunchCopy.textContent = `The nearest stop, ${stop.title || 'this stop'}, is unlocked. On WebXR-capable phones you can place the guide on a detected surface, and on other phones you can use Camera Guide mode with the same stop video.`;
        } else if (canLaunchCamera) {
          arLaunchCopy.textContent = `The nearest stop, ${stop.title || 'this stop'}, is unlocked. Camera Guide mode is ready for this phone, and the standard video player is still available below.`;
        } else if (canLaunchAr) {
          arLaunchCopy.textContent = `The nearest stop, ${stop.title || 'this stop'}, is unlocked. Launch the AR guide to place the video on a detected surface, or use the standard video player.`;
        } else {
          arLaunchCopy.textContent = `The nearest stop, ${stop.title || 'this stop'}, is unlocked. Use the standard video player while this browser's camera and AR capabilities are limited.`;
        }
      } else {
        arLaunchCopy.textContent = `The nearest stop, ${stop.title || 'this stop'}, is unlocked, but it does not have a Mux video yet.`;
      }
    } else {
      arLaunchCopy.textContent = 'Temporary debug override is keeping this launch section visible even though no unlocked active stop is currently available.';
    }

    if (cameraLaunchButton) {
      cameraLaunchButton.style.display = hasGuideVideo && isUnlocked ? 'inline-block' : 'none';
    }

    setButtonState(arLaunchButton, canLaunchAr);
    setButtonState(cameraLaunchButton, Boolean(isUnlocked && hasGuideVideo && cameraGuideSupported));
    setButtonState(standardVideoButton, Boolean(isUnlocked && hasStandardVideo));
    updateDebugPanel(stop);
  }

  function updateLaunchState(stop) {
    updateLaunchUi(stop);
  }

  if (debugMounted) {
    debugMounted.textContent = 'Section mounted: yes';
  }
  if (runtimeStarted) {
    runtimeStarted.textContent = 'Script started: yes';
  }
  setRuntimeStep('script top reached');
  setRuntimeError('none');

  try {
    setRuntimeStep('binding launch buttons');
    arLaunchButton?.addEventListener('click', () => {
      if (currentActiveStop?.isUnlocked && getGuideVideoUrl(currentActiveStop)) {
        startArSession(currentActiveStop);
      }
    });

    cameraLaunchButton?.addEventListener('click', () => {
      if (currentActiveStop?.isUnlocked && getGuideVideoUrl(currentActiveStop)) {
        startCameraGuide(currentActiveStop);
      }
    });

    standardVideoButton?.addEventListener('click', () => {
      standardVideoContainer?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      standardVideoPlayer?.play?.().catch(() => {});
    });

    arCloseButton?.addEventListener('click', () => {
      endArSession();
    });

    arResetGuideButton?.addEventListener('click', () => {
      resetPlacement();
    });

    cameraCloseButton?.addEventListener('click', () => {
      stopCameraGuide();
    });

    cameraResetButton?.addEventListener('click', () => {
      resetCameraPanelPosition();
    });

    cameraPosCenterButton?.addEventListener('click', () => {
      applyPresetPlacement('center');
    });

    cameraPosLeftButton?.addEventListener('click', () => {
      applyPresetPlacement('left');
    });

    cameraPosRightButton?.addEventListener('click', () => {
      applyPresetPlacement('right');
    });

    cameraStandardVideoButton?.addEventListener('click', () => {
      stopCameraGuide();
      standardVideoContainer?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      standardVideoPlayer?.play?.().catch(() => {});
    });

    cameraPlaceHereButton?.addEventListener('click', () => {
      setCameraPlacementMode(!cameraPlacementMode);
    });

    setRuntimeStep('binding drag handlers');
    cameraPanelHandle?.addEventListener('pointerdown', (event) => {
      if (!cameraPanel || !cameraPanelHandle) return;

      cameraPanelHandle.setPointerCapture(event.pointerId);
      const rect = cameraPanel.getBoundingClientRect();
      panelDrag = {
        pointerId: event.pointerId,
        offsetX: event.clientX - rect.left,
        offsetY: event.clientY - rect.top,
      };
      cameraPanelHandle.style.cursor = 'grabbing';
      cameraPanel.style.transition = 'none';
      cameraPanel.style.transform = 'none';
    });

    cameraPanelHandle?.addEventListener('pointermove', (event) => {
      if (!cameraPanel || !panelDrag || panelDrag.pointerId !== event.pointerId) return;

      const nextLeft = event.clientX - panelDrag.offsetX;
      const nextTop = event.clientY - panelDrag.offsetY;
      cameraPanel.style.left = `${Math.max(12, Math.min(window.innerWidth - cameraPanel.offsetWidth - 12, nextLeft))}px`;
      cameraPanel.style.top = `${Math.max(100, Math.min(window.innerHeight - cameraPanel.offsetHeight - 12, nextTop))}px`;
      syncCameraShadow();
    });

    cameraPanelHandle?.addEventListener('pointerup', (event) => {
      if (!cameraPanelHandle) return;
      if (panelDrag?.pointerId === event.pointerId) {
        panelDrag = null;
        cameraPanelHandle.releasePointerCapture(event.pointerId);
        cameraPanelHandle.style.cursor = 'grab';
        cameraPanel.style.transition = 'left 180ms ease, top 180ms ease, transform 180ms ease';
        syncCameraShadow();
      }
    });

    cameraPanelHandle?.addEventListener('pointercancel', (event) => {
      if (!cameraPanelHandle) return;
      if (panelDrag?.pointerId === event.pointerId) {
        panelDrag = null;
        cameraPanelHandle.style.cursor = 'grab';
        cameraPanel.style.transition = 'left 180ms ease, top 180ms ease, transform 180ms ease';
        syncCameraShadow();
      }
    });

    setRuntimeStep('binding camera placement interaction');
    cameraOverlay?.addEventListener('pointerdown', (event) => {
      if (!cameraPlacementMode || !cameraPanel || !cameraOverlay) return;

      const target = event.target;
      if (
        target instanceof Element &&
        (target.closest('#recxr-camera-panel') ||
          target.closest('#recxr-camera-close') ||
          target.closest('#recxr-camera-reset') ||
          target.closest('#recxr-camera-standard-video') ||
          target.closest('#recxr-camera-place-here') ||
          target.closest('#recxr-camera-pos-center') ||
          target.closest('#recxr-camera-pos-left') ||
          target.closest('#recxr-camera-pos-right'))
      ) {
        return;
      }

      const panelWidth = cameraPanel.offsetWidth;
      const panelHeight = cameraPanel.offsetHeight;
      const nextLeft = Math.max(12, Math.min(window.innerWidth - panelWidth - 12, event.clientX - panelWidth / 2));
      const nextTop = Math.max(100, Math.min(window.innerHeight - panelHeight - 12, event.clientY - panelHeight / 2));

      setCameraPanelPosition(`${nextLeft}px`, `${nextTop}px`, { center: false, smooth: true });
      setCameraPlacementMode(false);

      if (cameraStatus) {
        cameraStatus.textContent = 'Guide panel placed. Drag it further if you want to refine the position.';
      }
    });

    setRuntimeStep('binding active stop listener');
    // This listener handles the client-side geolocation result once the page determines the active stop.
    window.addEventListener('recxr-active-stop', (event) => {
      const stop = event.detail || null;
      currentActiveStop = stop;
      logGuideVideoResolution('recxr-active-stop event', stop);
      updateCameraGuideDebug(stop);
      updateLaunchState(stop);
      setRuntimeStep('received recxr-active-stop event');
    });

    setRuntimeStep('binding unload cleanup');
    window.addEventListener('beforeunload', () => {
      stopCameraGuide();
    });

    setRuntimeStep('running capability detection');
    updateArCapabilityMessage()
      .then(() => {
        setRuntimeStep('capability detection complete');
        updateDebugPanel(currentActiveStop);
        updateLaunchState(currentActiveStop);
        if (runtimeCompleted) {
          runtimeCompleted.textContent = 'Script completed: yes';
        }
      })
      .catch((error) => {
        setRuntimeError(error instanceof Error ? error.message : 'Unknown async initialization error');
      });
  } catch (error) {
    setRuntimeError(error instanceof Error ? error.message : 'Unknown initialization error');
  }
</script>
