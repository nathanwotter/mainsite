---
interface Props {
    node: {
        fileUrl?: string;
        title?: string;
        caption?: string;
        filename?: string;
        extension?: string;
        size?: number;
    };
}

const { node } = Astro.props;

function formatFileMeta(extension?: string, size?: number) {
    const parts = [];

    if (extension) {
        parts.push(extension.toUpperCase());
    }

    if (typeof size === 'number' && size > 0) {
        const units = ['B', 'KB', 'MB', 'GB'];
        let value = size;
        let unitIndex = 0;

        while (value >= 1024 && unitIndex < units.length - 1) {
            value = value / 1024;
            unitIndex += 1;
        }

        parts.push(`${value >= 10 || unitIndex === 0 ? Math.round(value) : value.toFixed(1)} ${units[unitIndex]}`);
    }

    return parts.join(' · ');
}

const fileMeta = formatFileMeta(node.extension, node.size);
const label = node.title || node.filename || 'Download file';
---

{
    node.fileUrl && (
        <div class="page-file-block">
            <a class="page-file-link" href={node.fileUrl} download>
                <span>{label}</span>
                {fileMeta && <small>{fileMeta}</small>}
            </a>
            {node.caption && <p>{node.caption}</p>}
        </div>
    )
}
