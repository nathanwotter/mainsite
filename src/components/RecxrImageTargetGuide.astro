---
---

<div
  id="recxr-image-target-overlay"
  data-recxr-surface-overlay
  style="display: none; position: fixed; inset: 0; z-index: 1001; background: #000; color: #fff; overflow: hidden; pointer-events: none; padding: env(safe-area-inset-top) 0 env(safe-area-inset-bottom) 0;"
>
  <div
    id="recxr-image-target-stage"
    style="position: absolute; inset: 0; z-index: 0; overflow: hidden; background: transparent; pointer-events: auto;"
  ></div>

  <div
    id="recxr-image-target-scrim"
    style="position: absolute; inset: 0; z-index: 1; pointer-events: none; background: linear-gradient(to bottom, rgba(6, 10, 16, 0.82), rgba(6, 10, 16, 0.08) 24%, rgba(6, 10, 16, 0.22) 52%, rgba(6, 10, 16, 0.88));"
  ></div>

  <div data-recxr-surface-ui style="position: relative; z-index: 2; min-height: 100%; padding: calc(0.75rem + env(safe-area-inset-top)) 0.9rem calc(1rem + env(safe-area-inset-bottom)) 0.9rem; pointer-events: none; display: flex; flex-direction: column; justify-content: space-between;">
    <div style="display: grid; gap: 0.75rem;">
      <div style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: start;">
        <div id="recxr-image-target-instruction-pill" style="max-width: min(24rem, calc(100vw - 7rem)); padding: 0.7rem 0.9rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.16); background: rgba(8, 12, 18, 0.74); backdrop-filter: blur(10px); box-shadow: 0 18px 48px rgba(0,0,0,0.24);">
          <p id="recxr-image-target-instruction-kicker" style="margin: 0; line-height: 1.3; color: #f8fafc; font-size: 0.96rem; font-weight: 700;">
            Get ready
          </p>
        </div>
      <button
        id="recxr-image-target-close"
        type="button"
          style="display: inline-flex; align-items: center; justify-content: center; min-width: 2.9rem; min-height: 2.9rem; padding: 0.8rem; border: 1px solid rgba(255,255,255,0.28); color: #fff; background: rgba(8, 12, 18, 0.72); border-radius: 999px; cursor: pointer; pointer-events: auto; backdrop-filter: blur(10px);"
          aria-label="Close Surface Guide"
      >
        Close
      </button>
    </div>

      <div id="recxr-image-target-stop-card" style="display: inline-grid; gap: 0.3rem; width: min(19rem, 100%); padding: 0.85rem 0.95rem; border-radius: 20px; border: 1px solid rgba(255,255,255,0.16); background: rgba(8, 12, 18, 0.74); backdrop-filter: blur(10px); box-shadow: 0 18px 48px rgba(0,0,0,0.24);">
        <p id="recxr-image-target-stop-meta" style="margin: 0; font-size: 0.76rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #c4b5fd;">
          Stop 1 of 1
        </p>
        <h2 id="recxr-image-target-title" style="margin: 0; font-size: 1.05rem; line-height: 1.2; color: #fff;">
          Preparing surface placement...
        </h2>
        <p id="recxr-image-target-next-stop" style="margin: 0; font-size: 0.9rem; color: #d1d5db;">
          Next stop distance coming soon.
        </p>
      </div>
    </div>

    <div style="display: grid; gap: 0.8rem; align-self: stretch;">
      <div
        id="recxr-image-target-banner"
        style="display: none; margin: 0 auto; width: min(28rem, 100%); padding: 0.8rem 0.95rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.18); background: rgba(8, 12, 18, 0.74); backdrop-filter: blur(10px);"
      >
        <p
          id="recxr-image-target-banner-label"
          style="margin: 0 0 0.2rem 0; font-size: 0.74rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #bfdbfe;"
        >
          Status
        </p>
        <p id="recxr-image-target-banner-copy" style="margin: 0; color: #f8fafc; line-height: 1.45;">
          Preparing surface placement test...
        </p>
      </div>

      <div id="recxr-image-target-action-bar" data-recxr-surface-controls style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.55rem; pointer-events: auto; align-self: stretch;">
        <button id="recxr-image-target-map" type="button" style="min-height: 3.3rem; padding: 0.85rem 0.7rem; border: 1px solid rgba(255,255,255,0.18); color: #fff; background: rgba(8, 12, 18, 0.78); border-radius: 18px; cursor: pointer; font-weight: 700;">Map</button>
        <button id="recxr-image-target-reset-placement" type="button" style="min-height: 3.3rem; padding: 0.85rem 0.7rem; border: 1px solid rgba(255,255,255,0.18); color: #fff; background: rgba(8, 12, 18, 0.78); border-radius: 18px; cursor: pointer; font-weight: 700;">Recenter</button>
        <button id="recxr-image-target-audio" type="button" style="min-height: 3.3rem; padding: 0.85rem 0.7rem; border: 1px solid rgba(255,255,255,0.18); color: #fff; background: rgba(8, 12, 18, 0.78); border-radius: 18px; cursor: pointer; font-weight: 700;">Audio</button>
      </div>
    </div>

    <div id="recxr-image-target-debug-grid" style="display: grid; gap: 0.85rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); margin-top: 0.8rem;">
      <div style="padding: 1rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05);">
        <p style="margin: 0 0 0.4rem 0; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #f9a8d4;">
          Placement Status
        </p>
        <p id="recxr-image-target-status" style="margin: 0; color: #f3f4f6; line-height: 1.7;">
          Waiting for a stop with guide media.
        </p>
      </div>

      <div id="recxr-image-target-debug-card" style="padding: 1rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.03);">
        <p style="margin: 0 0 0.4rem 0; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #93c5fd;">
          Temp Surface Debug
        </p>
        <p id="recxr-image-target-debug-surface" style="margin: 0 0 0.2rem 0; color: #dbeafe;">surface candidate available: no</p>
        <p id="recxr-image-target-debug-hit" style="margin: 0 0 0.2rem 0; color: #dbeafe;">chosen hit type: none</p>
        <p id="recxr-image-target-debug-placed" style="margin: 0 0 0.2rem 0; color: #dbeafe;">Nathan placed: no</p>
        <p id="recxr-image-target-debug-tracking" style="margin: 0 0 0.2rem 0; color: #dbeafe;">SLAM tracking state: unknown</p>
        <p id="recxr-image-target-debug-count" style="margin: 0 0 0.2rem 0; color: #dbeafe;">hit test candidates per frame: 0</p>
        <p id="recxr-image-target-debug-reject" style="margin: 0 0 0.2rem 0; color: #dbeafe;">candidate reject reason: none</p>
        <p id="recxr-image-target-debug-layout" style="margin: 0 0 0.2rem 0; color: #dbeafe;">stage/canvas layout: unknown</p>
        <p id="recxr-image-target-debug-dom" style="margin: 0 0 0.2rem 0; color: #dbeafe;">overlay/stage/canvas visibility: unknown</p>
        <p id="recxr-image-target-debug-render" style="margin: 0 0 0.2rem 0; color: #dbeafe;">camera render module active: unknown</p>
        <p id="recxr-image-target-debug-owner" style="margin: 0 0 0.2rem 0; color: #dbeafe;">XR render owner: unknown</p>
        <p id="recxr-image-target-debug-injected" style="margin: 0 0 0.2rem 0; color: #dbeafe;">foreign XR layers in body: none</p>
        <p id="recxr-image-target-debug-modules" style="margin: 0 0 0.2rem 0; color: #dbeafe;">active pipeline modules: unknown</p>
        <p id="recxr-image-target-debug-frames" style="margin: 0 0 0.2rem 0; color: #dbeafe;">visible canvas draw frames: 0</p>
        <p id="recxr-image-target-debug-alpha" style="margin: 0; color: #dbeafe;">renderer alpha/composition: unknown</p>
      </div>
    </div>

    <div id="recxr-image-target-config-panel" style="padding: 0.9rem 1rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.03);">
      <p style="margin: 0 0 0.45rem 0; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #93c5fd;">
        Runtime Config
      </p>
      <p id="recxr-image-target-config" style="margin: 0; color: #dbeafe; line-height: 1.7;">
        No surface-placement stop is active yet.
      </p>
      <p id="recxr-image-target-config-debug" style="margin: 0.55rem 0 0 0; color: #bfdbfe; line-height: 1.7; font-size: 0.92rem;">
        imageTargetWidth=unset | anchorOffsetX=0 | anchorOffsetY=0 | anchorOffsetZ=0 | anchorYaw=0
      </p>
    </div>
  </div>

</div>

<script>
  import { startSelfHosted8thWallSession, stopSelfHosted8thWallSession, getSelfHosted8thWallPaths } from '../lib/ar/8thwall/engine';
  import { getUprightGuidePlacement } from '../lib/ar/placement/uprightPlacement';

  const imageTargetOverlay = document.getElementById('recxr-image-target-overlay');
  const imageTargetStage = document.getElementById('recxr-image-target-stage');
  const imageTargetTitle = document.getElementById('recxr-image-target-title');
  const imageTargetInstructionKicker = document.getElementById('recxr-image-target-instruction-kicker');
  const imageTargetStopMeta = document.getElementById('recxr-image-target-stop-meta');
  const imageTargetNextStop = document.getElementById('recxr-image-target-next-stop');
  const imageTargetStatus = document.getElementById('recxr-image-target-status');
  const imageTargetMapButton = document.getElementById('recxr-image-target-map');
  const imageTargetAudioButton = document.getElementById('recxr-image-target-audio');
  const imageTargetConfig = document.getElementById('recxr-image-target-config');
  const imageTargetConfigDebug = document.getElementById('recxr-image-target-config-debug');
  const imageTargetDebugGrid = document.getElementById('recxr-image-target-debug-grid');
  const imageTargetDebugCard = document.getElementById('recxr-image-target-debug-card');
  const imageTargetConfigPanel = document.getElementById('recxr-image-target-config-panel');
  const imageTargetBanner = document.getElementById('recxr-image-target-banner');
  const imageTargetBannerLabel = document.getElementById('recxr-image-target-banner-label');
  const imageTargetBannerCopy = document.getElementById('recxr-image-target-banner-copy');
  const imageTargetCloseButton = document.getElementById('recxr-image-target-close');
  const imageTargetResetPlacementButton = document.getElementById('recxr-image-target-reset-placement');
  const imageTargetOpenCameraFallbackButton = document.getElementById('recxr-image-target-open-camera-fallback');
  const imageTargetDebugSurface = document.getElementById('recxr-image-target-debug-surface');
  const imageTargetDebugHit = document.getElementById('recxr-image-target-debug-hit');
  const imageTargetDebugPlaced = document.getElementById('recxr-image-target-debug-placed');
  const imageTargetDebugTracking = document.getElementById('recxr-image-target-debug-tracking');
  const imageTargetDebugCount = document.getElementById('recxr-image-target-debug-count');
  const imageTargetDebugReject = document.getElementById('recxr-image-target-debug-reject');
  const imageTargetDebugLayout = document.getElementById('recxr-image-target-debug-layout');
  const imageTargetDebugDom = document.getElementById('recxr-image-target-debug-dom');
  const imageTargetDebugRender = document.getElementById('recxr-image-target-debug-render');
  const imageTargetDebugOwner = document.getElementById('recxr-image-target-debug-owner');
  const imageTargetDebugInjected = document.getElementById('recxr-image-target-debug-injected');
  const imageTargetDebugModules = document.getElementById('recxr-image-target-debug-modules');
  const imageTargetDebugFrames = document.getElementById('recxr-image-target-debug-frames');
  const imageTargetDebugAlpha = document.getElementById('recxr-image-target-debug-alpha');

  let currentStop = null;
  let currentSurfaceAvailable = false;
  let currentHitType = 'none';
  let currentNathanPlaced = false;
  let currentRuntimeError = '';
  let currentTrackingStatus = 'unknown';
  let currentHitCount = 0;
  let currentRejectReason = 'none';
  let currentLayoutDebug = 'unknown';
  let currentDomDebug = 'unknown';
  let currentRenderDebug = 'unknown';
  let currentRenderOwnerDebug = 'unknown';
  let currentInjectedLayersDebug = 'none';
  let currentPipelineModulesDebug = 'unknown';
  let currentVisibleCanvasFrameCount = 0;
  let currentRendererAlphaDebug = 'unknown';
  let surfaceGuideOpening = false;
  let surfaceGuideOpen = false;
  const surfaceGuideDebugEnabled = false;

  function getExperienceUiState() {
    if (!currentStop) return 'navigating';
    if (currentNathanPlaced) return 'placed';
    if (currentSurfaceAvailable) return 'readyToPlace';
    if (currentTrackingStatus !== 'unknown') return 'scanning';
    return 'navigating';
  }

  function updateExperienceChrome() {
    const uiState = getExperienceUiState();
    const stopNumber = typeof currentStop?.index === 'number' ? currentStop.index + 1 : 1;
    const stopCount = typeof currentStop?.routeStopCount === 'number' ? currentStop.routeStopCount : stopNumber;

    if (imageTargetStopMeta) {
      imageTargetStopMeta.textContent = `Stop ${stopNumber} of ${stopCount}`;
    }
    if (imageTargetNextStop) {
      imageTargetNextStop.textContent =
        typeof currentStop?.nextStopDistanceMeters === 'number'
          ? `Next stop: ${Math.round(currentStop.nextStopDistanceMeters)} m`
          : 'Next stop distance coming soon.';
    }
    if (imageTargetInstructionKicker) {
      const instructionMap = {
        navigating: 'Get ready',
        scanning: 'Scan the ground',
        readyToPlace: 'Tap to place Nathan',
        placed: 'Nathan is ready',
      };
      imageTargetInstructionKicker.textContent = instructionMap[uiState];
    }
  }

  function logSurfaceGuide(message, details) {
    if (!surfaceGuideDebugEnabled) return;
    if (details !== undefined) {
      console.log('[RecXR][SurfaceGuide]', message, details);
    } else {
      console.log('[RecXR][SurfaceGuide]', message);
    }
  }

  function isLikelyIphone() {
    const ua = navigator.userAgent || '';
    return /iPhone|iPad|iPod/i.test(ua) || (/Macintosh/i.test(ua) && 'ontouchend' in document);
  }

  function getGuideVideoUrl(stop) {
    return stop?.arGuideHlsUrl || stop?.standardHlsUrl || stop?.hlsUrl || '';
  }

  function getResolvedGuideMode(stop) {
    if (stop?.videoMode === 'packedAlpha' && stop?.arGuideHlsUrl) {
      return 'packedAlpha';
    }

    return 'standard';
  }

  function getGuideWorldWidth(stop) {
    const configuredWidth = typeof stop?.imageTargetWidth === 'number' ? stop.imageTargetWidth : null;
    if (configuredWidth && configuredWidth > 0.45) {
      return configuredWidth;
    }

    return 0.82;
  }

  function setDebugState() {
    if (imageTargetDebugSurface) {
      imageTargetDebugSurface.textContent = `surface candidate available: ${currentSurfaceAvailable ? 'yes' : 'no'}`;
    }
    if (imageTargetDebugHit) {
      imageTargetDebugHit.textContent = `chosen hit type: ${currentHitType}`;
    }
    if (imageTargetDebugPlaced) {
      imageTargetDebugPlaced.textContent = `Nathan placed: ${currentNathanPlaced ? 'yes' : 'no'}`;
    }
    if (imageTargetDebugTracking) {
      imageTargetDebugTracking.textContent = `SLAM tracking state: ${currentTrackingStatus}`;
    }
    if (imageTargetDebugCount) {
      imageTargetDebugCount.textContent = `hit test candidates per frame: ${currentHitCount}`;
    }
    if (imageTargetDebugReject) {
      imageTargetDebugReject.textContent = `candidate reject reason: ${currentRejectReason}`;
    }
    if (imageTargetDebugLayout) {
      imageTargetDebugLayout.textContent = `stage/canvas layout: ${currentLayoutDebug}`;
    }
    if (imageTargetDebugDom) {
      imageTargetDebugDom.textContent = `overlay/stage/canvas visibility: ${currentDomDebug}`;
    }
    if (imageTargetDebugRender) {
      imageTargetDebugRender.textContent = `camera render module active: ${currentRenderDebug}`;
    }
    if (imageTargetDebugOwner) {
      imageTargetDebugOwner.textContent = `XR render owner: ${currentRenderOwnerDebug}`;
    }
    if (imageTargetDebugInjected) {
      imageTargetDebugInjected.textContent = `foreign XR layers in body: ${currentInjectedLayersDebug}`;
    }
    if (imageTargetDebugModules) {
      imageTargetDebugModules.textContent = `active pipeline modules: ${currentPipelineModulesDebug}`;
    }
    if (imageTargetDebugFrames) {
      imageTargetDebugFrames.textContent = `visible canvas draw frames: ${currentVisibleCanvasFrameCount}`;
    }
    if (imageTargetDebugAlpha) {
      imageTargetDebugAlpha.textContent = `renderer alpha/composition: ${currentRendererAlphaDebug}`;
    }
  }

  if (!surfaceGuideDebugEnabled) {
    imageTargetDebugCard?.setAttribute('style', 'display: none;');
    imageTargetConfigPanel?.setAttribute('style', 'display: none;');
    imageTargetDebugGrid?.setAttribute('style', 'display: block; margin-bottom: 1rem;');
  }
  updateExperienceChrome();

  function setStatusBanner(kind, message) {
    if (!imageTargetBanner || !imageTargetBannerLabel || !imageTargetBannerCopy) return;

    const bannerStyles = {
      loading: { label: 'Scanning', border: '1px solid rgba(147,197,253,0.35)', background: 'rgba(30, 41, 59, 0.86)', labelColor: '#93c5fd' },
      success: { label: 'Ready', border: '1px solid rgba(74,222,128,0.35)', background: 'rgba(20, 83, 45, 0.86)', labelColor: '#86efac' },
      warning: { label: 'Adjust', border: '1px solid rgba(250,204,21,0.35)', background: 'rgba(113, 63, 18, 0.88)', labelColor: '#fde047' },
      error: { label: 'Placement Error', border: '1px solid rgba(248,113,113,0.35)', background: 'rgba(127, 29, 29, 0.9)', labelColor: '#fca5a5' },
      info: { label: 'Status', border: '1px solid rgba(255,255,255,0.18)', background: 'rgba(255,255,255,0.06)', labelColor: '#bfdbfe' },
    };

    const style = bannerStyles[kind] || bannerStyles.info;
    imageTargetBanner.style.display = 'block';
    imageTargetBanner.style.border = style.border;
    imageTargetBanner.style.background = style.background;
    imageTargetBannerLabel.textContent = style.label;
    imageTargetBannerLabel.style.color = style.labelColor;
    imageTargetBannerCopy.textContent = message;
  }

  function updateSurfaceUi(stop) {
    currentStop = stop || null;
    currentSurfaceAvailable = false;
    currentHitType = 'none';
    currentNathanPlaced = false;
    currentRuntimeError = '';
    currentTrackingStatus = 'unknown';
    currentHitCount = 0;
    currentRejectReason = 'none';
    currentLayoutDebug = 'unknown';
    currentDomDebug = 'unknown';
    currentRenderDebug = 'unknown';
    currentRenderOwnerDebug = 'unknown';
    currentInjectedLayersDebug = 'none';
    currentPipelineModulesDebug = 'unknown';
    currentVisibleCanvasFrameCount = 0;
    currentRendererAlphaDebug = 'unknown';
    setDebugState();
    logSurfaceGuide('camera fallback button rendered', {
      visible: Boolean(imageTargetOpenCameraFallbackButton),
      surfaceGuideOpen,
      hasGuideVideo: Boolean(getGuideVideoUrl(stop)),
      isUnlocked: Boolean(stop?.isUnlocked),
    });

    if (imageTargetTitle) {
      imageTargetTitle.textContent = stop?.title || 'RecXR Surface Guide';
    }
    if (imageTargetStatus) {
      imageTargetStatus.textContent = stop
        ? 'Preparing SLAM surface placement...'
        : 'Waiting for a stop with guide media.';
    }
    setStatusBanner(
      'info',
      stop
        ? 'SLAM-only placement is active for this release. Scan for a floor or table surface, then tap to place Nathan.'
        : 'Waiting for a stop with guide media.'
    );
    if (imageTargetConfig) {
      const paths = getSelfHosted8thWallPaths();
      imageTargetConfig.textContent = stop
        ? `surfacePlacement=slam-only | videoMode=${getResolvedGuideMode(stop)} | engine=${paths.engineScriptUrl} | bridge=${paths.bridgeScriptUrl}`
        : 'No surface-placement stop is active yet.';
    }
    if (imageTargetConfigDebug) {
      imageTargetConfigDebug.textContent = stop
        ? `imageTargetWidth=${typeof stop.imageTargetWidth === 'number' ? stop.imageTargetWidth : 'unset'} | anchorOffsetX=${stop.anchorOffsetX ?? 0} | anchorOffsetY=${stop.anchorOffsetY ?? 0} | anchorOffsetZ=${stop.anchorOffsetZ ?? 0} | anchorYaw=${stop.anchorYaw ?? 0}`
        : 'imageTargetWidth=unset | anchorOffsetX=0 | anchorOffsetY=0 | anchorOffsetZ=0 | anchorYaw=0';
    }
    updateExperienceChrome();
  }

  function buildGuideSpec(stop) {
    const worldWidth = getGuideWorldWidth(stop);
    return {
      title: stop?.title || 'RecXR Guide',
      guideVideoUrl: getGuideVideoUrl(stop),
      standardHlsUrl: stop?.standardHlsUrl || stop?.hlsUrl || '',
      arGuideHlsUrl: stop?.arGuideHlsUrl || '',
      videoMode: getResolvedGuideMode(stop),
      imageTargetWidth: worldWidth,
    };
  }

  function buildPlacementSpec(stop) {
    const width = getGuideWorldWidth(stop);
    const guideHeight = width / 0.5625;
    const uprightPlacement = getUprightGuidePlacement(stop || {}, guideHeight);

    return {
      imageTargetWidth: width,
      upright: true,
      faceCameraYawOnly: true,
      detachToWorldOnGroundTap: true,
      ...uprightPlacement,
    };
  }

  async function startSurfacePlacement(stop) {
    if (!imageTargetStage || !stop) return;
    if (!isLikelyIphone()) {
      throw new Error('This self-hosted SLAM surface flow is currently intended for iPhone testing.');
    }
    if (!getGuideVideoUrl(stop)) {
      throw new Error('This stop does not have guide media to place on a surface.');
    }

    logSurfaceGuide('startSurfacePlacement entered', { title: stop?.title || null });
    await startSelfHosted8thWallSession({
      canvasContainer: imageTargetStage,
      debugEnabled: surfaceGuideDebugEnabled,
      guide: buildGuideSpec(stop),
      placement: buildPlacementSpec(stop),
      onStatus: (message) => {
        if (typeof message !== 'string') return;
        logSurfaceGuide('status', message);
        if (imageTargetStatus) {
          imageTargetStatus.textContent = message;
        }

        const lowerMessage = message.toLowerCase();
        if (lowerMessage.includes('no placeable horizontal-surface candidate')) {
          setStatusBanner('loading', 'Scanning for surface...');
        } else if (lowerMessage.includes('placeable surface candidate')) {
          setStatusBanner('success', 'Surface found. Ready to place Nathan.');
        } else if (lowerMessage.includes('placed in world space')) {
          setStatusBanner('success', 'Nathan placed.');
        } else if (lowerMessage.includes('starting') || lowerMessage.includes('session started')) {
          setStatusBanner('loading', 'Scanning for surface...');
        }
      },
      onSurfaceCandidate: (detail) => {
        currentSurfaceAvailable = Boolean(detail?.available);
        currentHitType = detail?.type || 'none';
        updateExperienceChrome();
        setDebugState();
      },
      onWorldPlaced: (detail) => {
        currentNathanPlaced = true;
        currentHitType = detail?.type || currentHitType || 'none';
        updateExperienceChrome();
        setDebugState();
        setStatusBanner('success', 'Nathan placed.');
        if (imageTargetStatus) {
          imageTargetStatus.textContent = `Nathan placed using ${currentHitType}. Tap Reposition Nathan to place him again.`;
        }
      },
      onPlacementReset: () => {
        currentNathanPlaced = false;
        updateExperienceChrome();
        setDebugState();
        setStatusBanner('loading', 'Scanning for surface...');
        if (imageTargetStatus) {
          imageTargetStatus.textContent = 'Placement reset. Move your phone slowly until a surface is found, then tap to place Nathan again.';
        }
      },
      onDebug: (detail) => {
        currentTrackingStatus = detail?.trackingStatus || currentTrackingStatus;
        currentHitCount = typeof detail?.hitResultCount === 'number' ? detail.hitResultCount : currentHitCount;
        currentRejectReason = detail?.rejectReason || currentRejectReason;
        if (
          typeof detail?.stageWidth === 'number' &&
          typeof detail?.stageHeight === 'number' &&
          typeof detail?.canvasWidth === 'number' &&
          typeof detail?.canvasHeight === 'number'
        ) {
          currentLayoutDebug = `${detail.stageWidth}x${detail.stageHeight} stage | ${detail.canvasWidth}x${detail.canvasHeight} canvas`;
        }
        if (detail?.overlayVisibility || detail?.stageVisibility || detail?.canvasVisibility) {
          currentDomDebug =
            `overlay=${detail.overlayVisibility || 'unknown'} z${detail.overlayZIndex || '?'} | ` +
            `stage=${detail.stageVisibility || 'unknown'} z${detail.stageZIndex || '?'} | ` +
            `canvas=${detail.canvasVisibility || 'unknown'} z${detail.canvasZIndex || '?'}`;
        }
        if (typeof detail?.cameraRenderModuleActive === 'boolean') {
          currentRenderDebug = detail.cameraRenderModuleActive ? 'yes' : 'no';
        }
        if (detail?.renderOwner) {
          currentRenderOwnerDebug = detail.renderOwner;
        }
        if (Array.isArray(detail?.foreignRenderLayers)) {
          currentInjectedLayersDebug = detail.foreignRenderLayers.length
            ? detail.foreignRenderLayers.join(', ')
            : 'none';
        }
        if (Array.isArray(detail?.activePipelineModules)) {
          currentPipelineModulesDebug = detail.activePipelineModules.join(', ') || 'none';
        }
        if (typeof detail?.visibleCanvasFrameCount === 'number') {
          currentVisibleCanvasFrameCount = detail.visibleCanvasFrameCount;
        }
        if (detail?.rendererAlphaDebug) {
          currentRendererAlphaDebug = detail.rendererAlphaDebug;
        }
        if (detail?.event === 'tracking' && imageTargetStatus && currentTrackingStatus !== 'unknown') {
          imageTargetStatus.textContent = `Scanning for surface... Tracking state: ${currentTrackingStatus}`;
        }
        updateExperienceChrome();
        setDebugState();
      },
      onError: (message) => {
        throw new Error(typeof message === 'string' ? message : 'Unknown 8th Wall integration error.');
      },
    });

    if (imageTargetStatus) {
      imageTargetStatus.textContent = 'Scanning for surface...';
    }
    setStatusBanner('loading', 'Scanning for surface...');
  }

  async function stopSurfacePlacement() {
    logSurfaceGuide('stopSurfacePlacement entered');
    await stopSelfHosted8thWallSession();
    if (imageTargetStage) {
      imageTargetStage.innerHTML = '';
    }
    surfaceGuideOpen = false;
  }

  async function openSurfaceGuide(stop) {
    if (surfaceGuideOpening) {
      logSurfaceGuide('openSurfaceGuide ignored because startup is already in flight');
      return;
    }
    if (surfaceGuideOpen && currentStop?._id === stop?._id) {
      logSurfaceGuide('openSurfaceGuide ignored because the same stop is already open');
      return;
    }
    surfaceGuideOpening = true;
    logSurfaceGuide('openSurfaceGuide entered', { title: stop?.title || null });
    updateSurfaceUi(stop);
    if (imageTargetOverlay) {
      imageTargetOverlay.style.display = 'block';
    }

    try {
      await stopSurfacePlacement();
      await startSurfacePlacement(stop);
      surfaceGuideOpen = true;
    } catch (error) {
      currentSurfaceAvailable = false;
      currentHitType = 'none';
      currentNathanPlaced = false;
      currentRuntimeError = error instanceof Error ? error.message : 'Unknown error';
      setDebugState();
      if (imageTargetStatus) {
        imageTargetStatus.textContent = `Surface placement could not start: ${currentRuntimeError}`;
      }
      setStatusBanner('error', currentRuntimeError);
    } finally {
      surfaceGuideOpening = false;
    }
  }

  async function closeSurfaceGuide() {
    logSurfaceGuide('closeSurfaceGuide entered');
    await stopSurfacePlacement();
    if (imageTargetOverlay) {
      imageTargetOverlay.style.display = 'none';
    }
    surfaceGuideOpen = false;
    surfaceGuideOpening = false;
  }

  imageTargetCloseButton?.addEventListener('click', () => {
    closeSurfaceGuide();
  });

  imageTargetMapButton?.addEventListener('click', () => {
    setStatusBanner('info', 'Map will be added in a later phase.');
  });

  imageTargetAudioButton?.addEventListener('click', () => {
    setStatusBanner('info', 'Audio controls stay on the current playback path in this phase.');
  });

  imageTargetResetPlacementButton?.addEventListener('click', async () => {
    await window.Recxr8thWallIntegration?.resetPlacement?.();
  });

  imageTargetOpenCameraFallbackButton?.addEventListener('click', async () => {
    if (!currentStop) return;
    logSurfaceGuide('camera guide launch action fired', {
      title: currentStop?.title || null,
      hasGuideVideo: Boolean(getGuideVideoUrl(currentStop)),
      isUnlocked: Boolean(currentStop?.isUnlocked),
    });
    await closeSurfaceGuide();
    window.dispatchEvent(new CustomEvent('recxr-open-camera-guide-fallback', { detail: currentStop }));
  });

  window.addEventListener('recxr-open-image-target-guide', (event) => {
    openSurfaceGuide(event.detail || null);
  });
</script>
