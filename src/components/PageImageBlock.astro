---
interface Props {
    node: {
        src?: string;
        alt?: string;
        caption?: string;
        dimensions?: {
            width?: number;
            height?: number;
        };
    };
}

const { node } = Astro.props;
const width = node.dimensions?.width;
const height = node.dimensions?.height;
---

{
    node.src && (
        <figure class="page-image-block">
            <img src={node.src} alt={node.alt || ''} width={width} height={height} loading="lazy" decoding="async" />
            {node.caption && <figcaption>{node.caption}</figcaption>}
        </figure>
    )
}

<style>
    .page-image-block {
        margin: 2rem 0;
    }

    .page-image-block img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 8px;
    }

    .page-image-block figcaption {
        margin-top: 0.55rem;
        color: color-mix(in oklab, var(--color-base-content) 72%, transparent);
        font-size: 0.92rem;
        line-height: 1.5;
    }
</style>
